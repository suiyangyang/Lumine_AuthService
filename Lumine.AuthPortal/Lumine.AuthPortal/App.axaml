<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Lumine.AuthPortal"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels"
             xmlns:vmPages="using:Lumine.AuthPortal.ViewModels.Pages"
             xmlns:views="using:Lumine.AuthPortal.Views.Pages"
             x:Class="Lumine.AuthPortal.App"
             RequestedThemeVariant="Light">

    <Application.Resources>
        <FontFamily x:Key="ChineseFont">avares://Lumine.AuthPortal/Assets/SimHei.ttf#SimHei, Microsoft YaHei UI, Segoe UI, Segoe UI Emoji, Segoe UI Symbol</FontFamily>
        <FontFamily x:Key="EmojiFont">Segoe UI Emoji, Segoe UI Symbol, Microsoft YaHei UI, avares://Lumine.AuthPortal/Assets/SimHei.ttf#SimHei</FontFamily>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F6FB" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TopbarBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfacePanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#EEF3F8" />
        <SolidColorBrush x:Key="SurfaceInsetBrush" Color="#F7F9FC" />
        <SolidColorBrush x:Key="SurfaceSoftBrush" Color="#E8EEF6" />
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#D5DEEA" />
        <SolidColorBrush x:Key="BorderStrongBrush" Color="#C2CEDD" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#334155" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B" />
        <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#E8EEF6" />
        <SolidColorBrush x:Key="SurfacePressedBrush" Color="#DDE7F4" />
        <SolidColorBrush x:Key="SurfaceSelectedBrush" Color="#DBEAFE" />
        <SolidColorBrush x:Key="SurfaceSelectedHoverBrush" Color="#D3E4FB" />
        <SolidColorBrush x:Key="SurfaceSelectedPressedBrush" Color="#C7DBF8" />
        <SolidColorBrush x:Key="BorderHoverBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="BorderActiveBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="BorderActiveStrongBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="TextOnSelectedBrush" Color="#0F172A" />
        <SolidColorBrush x:Key="TextAccentSoftBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="StatusInfoBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#1E40AF" />
        <SolidColorBrush x:Key="AccentBorderBrush" Color="#60A5FA" />
        <SolidColorBrush x:Key="AccentBorderStrongBrush" Color="#BFDBFE" />
        <SolidColorBrush x:Key="LinkBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="LinkHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="LinkPressedBrush" Color="#1E40AF" />
        <SolidColorBrush x:Key="SelectionBrush" Color="#BFDBFE" />
        <SolidColorBrush x:Key="DialogBackdropBrush" Color="#AA020617" />
        <SolidColorBrush x:Key="DangerBannerBackgroundBrush" Color="#2B1220" />
        <SolidColorBrush x:Key="DangerBannerBorderBrush" Color="#7F1D1D" />
        <SolidColorBrush x:Key="DangerBannerForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SuccessBannerBackgroundBrush" Color="#ECFDF5" />
        <SolidColorBrush x:Key="SuccessBannerBorderBrush" Color="#6EE7B7" />
        <SolidColorBrush x:Key="SuccessBannerForegroundBrush" Color="#065F46" />
        <SolidColorBrush x:Key="SuccessPillBackgroundBrush" Color="#0F766E" />
        <SolidColorBrush x:Key="SuccessPillForegroundBrush" Color="#ECFDF5" />
        <SolidColorBrush x:Key="DangerPillBackgroundBrush" Color="#7F1D1D" />
        <SolidColorBrush x:Key="DangerPillForegroundBrush" Color="#FEF2F2" />
        <SolidColorBrush x:Key="DangerSoftBackgroundBrush" Color="#FFF1F2" />
        <SolidColorBrush x:Key="DangerSoftHoverBackgroundBrush" Color="#FFE4E6" />
        <SolidColorBrush x:Key="DangerSoftPressedBackgroundBrush" Color="#FECDD3" />
        <SolidColorBrush x:Key="DangerSoftBorderBrush" Color="#FCA5A5" />
        <SolidColorBrush x:Key="DangerSoftHoverBorderBrush" Color="#FB7185" />
        <SolidColorBrush x:Key="DangerSoftPressedBorderBrush" Color="#E11D48" />
        <SolidColorBrush x:Key="DangerSoftForegroundBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="DangerSoftHoverForegroundBrush" Color="#9F1239" />
        <SolidColorBrush x:Key="DangerSoftPressedForegroundBrush" Color="#881337" />
        <SolidColorBrush x:Key="DangerSolidBackgroundBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="DangerSolidHoverBackgroundBrush" Color="#B91C1C" />
        <SolidColorBrush x:Key="DangerSolidPressedBackgroundBrush" Color="#991B1B" />
        <SolidColorBrush x:Key="DangerSolidBorderBrush" Color="#F87171" />
        <SolidColorBrush x:Key="DangerSolidHoverBorderBrush" Color="#FCA5A5" />
        <SolidColorBrush x:Key="DangerSolidPressedBorderBrush" Color="#FECACA" />
        <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#059669" />
        <SolidColorBrush x:Key="SuccessHoverBackgroundBrush" Color="#047857" />
        <SolidColorBrush x:Key="SuccessPressedBackgroundBrush" Color="#065F46" />
        <SolidColorBrush x:Key="SuccessBorderBrush" Color="#34D399" />
        <SolidColorBrush x:Key="SuccessHoverBorderBrush" Color="#6EE7B7" />
        <SolidColorBrush x:Key="SuccessPressedBorderBrush" Color="#A7F3D0" />
        <SolidColorBrush x:Key="RoleTagBackgroundBrush" Color="#312E81" />
        <SolidColorBrush x:Key="RoleTagForegroundBrush" Color="#E0E7FF" />
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
        <DataTemplate DataType="vmPages:DashboardPageViewModel">
            <views:DashboardPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:LoginPageViewModel">
            <views:LoginPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:RegisterPageViewModel">
            <views:RegisterPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:ConsentPageViewModel">
            <views:ConsentPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:UsersManagementPageViewModel">
            <views:UsersManagementPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:RolesManagementPageViewModel">
            <views:RolesManagementPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:PermissionsManagementPageViewModel">
            <views:PermissionsManagementPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:ClientsManagementPageViewModel">
            <views:ClientsManagementPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:AuditLogsPageViewModel">
            <views:AuditLogsPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:OidcPlaygroundPageViewModel">
            <views:OidcPlaygroundPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:ProfileCenterPageViewModel">
            <views:ProfileCenterPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:SecuritySettingsPageViewModel">
            <views:SecuritySettingsPageView />
        </DataTemplate>
        <DataTemplate DataType="vmPages:SystemSettingsPageViewModel">
            <views:SystemSettingsPageView />
        </DataTemplate>
        <DataTemplate DataType="vm:PlaceholderPageViewModel">
            <views:PlaceholderPageView />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Border.dialog-backdrop">
            <Setter Property="Background" Value="{DynamicResource DialogBackdropBrush}" />
        </Style>
        <Style Selector="Border.dialog-card">
            <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
        </Style>
        <Style Selector="Border.info-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style Selector="Border.admin-panel">
            <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
        </Style>
        <Style Selector="Border.admin-status-banner">
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.admin-danger-banner">
            <Setter Property="Background" Value="{DynamicResource DangerBannerBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBannerBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.admin-row-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.admin-search-shell">
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="0,0,6,0" />
            <Setter Property="MinHeight" Value="42" />
        </Style>
        <Style Selector="TextBox.admin-search-input">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="14,10" />
        </Style>
        <Style Selector="Border.admin-content-block">
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
        </Style>
        <Style Selector="Border.admin-reference-card">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20,16" />
        </Style>
        <Style Selector="Border.admin-pill">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style Selector="Border.admin-pill.admin-pill-muted">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
        <Style Selector="Border.admin-pill.admin-pill-success">
            <Setter Property="Background" Value="{DynamicResource SuccessPillBackgroundBrush}" />
        </Style>
        <Style Selector="Border.admin-pill.admin-pill-danger">
            <Setter Property="Background" Value="{DynamicResource DangerPillBackgroundBrush}" />
        </Style>
        <Style Selector="TextBlock.admin-section-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.admin-reference-title">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.admin-reference-line">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
        <Style Selector="TextBlock.admin-card-title">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.admin-hint">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.admin-table-header">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.admin-muted">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style Selector="TextBlock.admin-info-title">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="TextBlock.admin-info-body">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Button.admin-button">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.admin-button /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-button /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-button /template/ Border#border">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
        </Style>
        <Style Selector="Button.admin-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-button:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-button:pointerover /template/ Border#border">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
        </Style>
        <Style Selector="Button.admin-button:pressed">
            <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-button:pressed /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-button:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-button:pressed /template/ Border#border">
            <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
        </Style>
        <Style Selector="Button.admin-button:disabled">
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="Opacity" Value="0.9" />
        </Style>
        <Style Selector="Button.admin-button:disabled /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style Selector="Button.admin-button:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style Selector="Button.admin-button:disabled /template/ Border#border">
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-compact">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinWidth" Value="72" />
        </Style>
        <Style Selector="Button.admin-icon-button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="40" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button:pressed">
            <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button:disabled">
            <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button.admin-primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button.admin-primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button.admin-danger">
            <Setter Property="Background" Value="{DynamicResource DangerSoftBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerSoftBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerSoftForegroundBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button.admin-danger:pointerover">
            <Setter Property="Background" Value="{DynamicResource DangerSoftHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerSoftHoverBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerSoftHoverForegroundBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button.admin-danger-solid">
            <Setter Property="Background" Value="{DynamicResource DangerSolidBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerSolidBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-icon-button.admin-danger-solid:pointerover">
            <Setter Property="Background" Value="{DynamicResource DangerSolidHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerSolidHoverBorderBrush}" />
        </Style>
        <Style Selector="Button.admin-row-icon-button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.admin-row-icon-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.admin-row-icon-button.admin-danger">
            <Setter Property="Background" Value="{DynamicResource DangerSoftBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerSoftBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerSoftForegroundBrush}" />
        </Style>
        <Style Selector="Button.admin-row-icon-button.admin-danger:pointerover">
            <Setter Property="Background" Value="{DynamicResource DangerSoftHoverBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DangerSoftHoverBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource DangerSoftHoverForegroundBrush}" />
        </Style>
        <Style Selector="PathIcon.admin-button-icon">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
        </Style>
        <Style Selector="PathIcon.admin-row-button-icon">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary /template/ Border#border">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary:pointerover /template/ Border#border">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary:pressed /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-primary:pressed /template/ Border#border">
            <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}" />
        </Style>
        <Style Selector="Button.admin-button.admin-success">
            <Setter Property="Background" Value="{DynamicResource SuccessBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
