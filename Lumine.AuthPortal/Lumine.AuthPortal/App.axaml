            <Setter Property="BorderBrush" Value="#374151" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.admin-button /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#F9FAFB" />
        </Style>
