<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.RegisterPageView"
             x:DataType="vm:RegisterPageViewModel">
  <UserControl.Styles>
    <Style Selector="TextBlock.form-label">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="Border.register-shell">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="36,34"/>
    </Style>
    <Style Selector="Border.register-panel">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="TextBox.register-input">
      <Setter Property="MinHeight" Value="44"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="SelectionBrush" Value="#3B82F6"/>
    </Style>
    <Style Selector="TextBox.register-input /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
    </Style>
    <Style Selector="TextBox.register-input:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
    </Style>
    <Style Selector="TextBox.register-input:pointerover /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
    </Style>
    <Style Selector="TextBox.register-input:focus">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBox.register-input:focus /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
    </Style>
    <Style Selector="Button.register-primary-action">
      <Setter Property="Background" Value="#2563EB"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,11"/>
    </Style>
    <Style Selector="Button.register-primary-action /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.register-primary-action /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#2563EB"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.register-primary-action /template/ Border#border">
      <Setter Property="Background" Value="#2563EB"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
    </Style>
    <Style Selector="Button.register-primary-action:pointerover">
      <Setter Property="Background" Value="#1D4ED8"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveStrongBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.register-primary-action:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.register-primary-action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#1D4ED8"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveStrongBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.register-primary-action:pointerover /template/ Border#border">
      <Setter Property="Background" Value="#1D4ED8"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveStrongBrush}"/>
    </Style>
    <Style Selector="Button.register-link-action">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Foreground" Value="#2563EB"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Right"/>
    </Style>
    <Style Selector="Button.register-link-action:pointerover">
      <Setter Property="Foreground" Value="#1D4ED8"/>
    </Style>
    <Style Selector="Button.register-link-action:pressed">
      <Setter Property="Foreground" Value="#1E40AF"/>
    </Style>
    <Style Selector="Border.register-status-banner">
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12"/>
    </Style>
    <Style Selector="Border.register-status-banner.status-error">
      <Setter Property="Background" Value="#FEF2F2"/>
      <Setter Property="BorderBrush" Value="#FCA5A5"/>
    </Style>
    <Style Selector="Border.register-status-banner.status-success">
      <Setter Property="Background" Value="#ECFDF5"/>
      <Setter Property="BorderBrush" Value="#6EE7B7"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*,Auto,*" Background="{DynamicResource AppBackgroundBrush}">
    <Border Grid.Row="1"
            Grid.Column="1"
            MinWidth="360"
            MaxWidth="560">
      <Border Classes="register-shell">
        <Grid RowDefinitions="Auto,*,Auto">
          <StackPanel Spacing="8">
            <TextBlock Text="创建账号"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
          </StackPanel>

          <Border Grid.Row="1"
                  Classes="register-panel"
                  VerticalAlignment="Center">
            <StackPanel Spacing="12">
              <TextBlock Text="账号信息"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         FontWeight="SemiBold"/>

              <Grid ColumnDefinitions="*,*"
                    ColumnSpacing="12"
                    RowDefinitions="Auto,Auto,Auto"
                    RowSpacing="12">
                <StackPanel Spacing="6">
                  <TextBlock Text="用户名" Classes="form-label"/>
                  <TextBox Text="{Binding UserName}" Classes="register-input" Watermark="请输入用户名" IsEnabled="{Binding CanInteract}" KeyDown="RegisterInput_OnKeyDown"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="6">
                  <TextBlock Text="邮箱" Classes="form-label"/>
                  <TextBox Text="{Binding Email}" Classes="register-input" Watermark="name@example.com" IsEnabled="{Binding CanInteract}" KeyDown="RegisterInput_OnKeyDown"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Spacing="6">
                  <TextBlock Text="密码" Classes="form-label"/>
                  <TextBox Text="{Binding Password}" Classes="register-input" PasswordChar="●" Watermark="请输入密码" IsEnabled="{Binding CanInteract}" KeyDown="RegisterInput_OnKeyDown"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                  <TextBlock Text="昵称" Classes="form-label"/>
                  <TextBox Text="{Binding NickName}" Classes="register-input" Watermark="选填" IsEnabled="{Binding CanInteract}" KeyDown="RegisterInput_OnKeyDown"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="6">
                  <TextBlock Text="手机号" Classes="form-label"/>
                  <TextBox Text="{Binding PhoneNumber}" Classes="register-input" Watermark="选填" IsEnabled="{Binding CanInteract}" KeyDown="RegisterInput_OnKeyDown"/>
                </StackPanel>
              </Grid>

              <Button Classes="register-primary-action"
                      Content="{Binding RegisterButtonText}"
                      Command="{Binding RegisterCommand}"
                      IsEnabled="{Binding CanInteract}"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      FontWeight="SemiBold"/>

              <Button Classes="register-link-action"
                      Content="去登录"
                      Command="{Binding OpenLoginCommand}"
                      IsEnabled="{Binding CanInteract}"
                      HorizontalAlignment="Right"/>
            </StackPanel>
          </Border>

          <Border Grid.Row="2"
                  Classes="register-status-banner"
                  Classes.status-error="{Binding IsErrorMessage}"
                  Classes.status-success="{Binding IsSuccessMessage}"
                  IsVisible="{Binding HasStatusMessage}"
                  MinHeight="46">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center"/>
          </Border>
        </Grid>
      </Border>
    </Border>
  </Grid>
</UserControl>
