<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.SecuritySettingsPageView"
             x:DataType="vm:SecuritySettingsPageViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16">
      <Border Background="{DynamicResource SurfacePanelBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="18" Padding="20">
        <StackPanel Spacing="10">
          <TextBlock Text="安全设置" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="{Binding SecurityStatus}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <ItemsControl ItemsSource="{Binding SecurityCards}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="4"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SecurityCardItemViewModel">
            <Border Background="{DynamicResource SurfaceRaisedBrush}" CornerRadius="14" Margin="0,0,12,0" Padding="16">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextMutedBrush}"/>
                <TextBlock Text="{Binding Value}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="16">
        <Border Background="{DynamicResource SurfacePanelBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="16" Padding="20">
          <StackPanel Spacing="14">
            <TextBlock Text="修改密码" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <StackPanel Spacing="6">
              <TextBlock Text="当前密码" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBox Text="{Binding CurrentPassword}" PasswordChar="●" Watermark="请输入当前密码"/>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="新密码" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBox Text="{Binding NewPassword}" PasswordChar="●" Watermark="请输入新密码"/>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="确认新密码" Foreground="{DynamicResource TextMutedBrush}"/>
              <TextBox Text="{Binding ConfirmNewPassword}" PasswordChar="●" Watermark="请再次输入新密码"/>
            </StackPanel>
            <Button Content="立即修改密码"
                    Classes="admin-button admin-primary"
                    Command="{Binding ChangePasswordCommand}"
                    Padding="14,8"/>

            <TextBlock Text="安全建议" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0"/>
            <ItemsControl ItemsSource="{Binding SecurityTips}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="{DynamicResource SurfaceRaisedBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                      <TextBlock Text="•" Foreground="{DynamicResource StatusInfoBrush}" FontSize="18" VerticalAlignment="Top"/>
                      <TextBlock Grid.Column="1" Text="{Binding .}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource SurfacePanelBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="16" Padding="20">
          <StackPanel Spacing="14">
            <TextBlock Text="设备与会话" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
            <ItemsControl ItemsSource="{Binding DeviceActivities}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:SecurityActivityItemViewModel">
                  <Border Background="{DynamicResource SurfaceRaisedBrush}" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                    <StackPanel Spacing="6">
                      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding TimeText}" Foreground="{DynamicResource TextMutedBrush}"/>
                      </Grid>
                      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource StatusInfoBrush}"/>
                      <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
