<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             xmlns:model="using:Lumine.AuthPortal.Models"
             x:Class="Lumine.AuthPortal.Views.Pages.PermissionsManagementPageView"
             x:Name="Root"
             x:DataType="vm:PermissionsManagementPageViewModel">
  <Grid>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        <Border Classes="admin-panel" Padding="18">
          <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock Text="权限列表" Classes="admin-card-title"/>
                <TextBlock Text="维护权限编码、显示名称与后续页面/API 映射。" Classes="admin-hint"/>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="admin-icon-button"
                        Command="{Binding ToggleSearchCommand}"
                        Click="ToggleSearchButton_OnClick"
                        ToolTip.Tip="搜索权限">
                  <PathIcon Data="{Binding SearchIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button"
                        Command="{Binding LoadCommand}"
                        ToolTip.Tip="刷新列表">
                  <PathIcon Data="{Binding RefreshIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button admin-primary"
                        Command="{Binding OpenCreateDialogCommand}"
                        ToolTip.Tip="新增权限">
                  <PathIcon Data="{Binding AddIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button"
                        Command="{Binding OpenEditDialogCommand}"
                        IsEnabled="{Binding HasSelectedPermission}"
                        ToolTip.Tip="编辑权限">
                  <PathIcon Data="{Binding EditIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button admin-danger"
                        Command="{Binding DeleteCommand}"
                        IsEnabled="{Binding HasSelectedPermission}"
                        ToolTip.Tip="删除权限">
                  <PathIcon Data="{Binding DeleteIconData}" Classes="admin-button-icon"/>
                </Button>
              </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Classes="admin-search-shell"
                    IsVisible="{Binding IsSearchVisible}">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                <TextBox x:Name="PermissionSearchTextBox"
                         Classes="admin-search-input"
                         Text="{Binding SearchKeyword}"
                         Watermark="搜索权限名称或显示名，按 Enter 执行"
                         KeyDown="PermissionSearchTextBox_OnKeyDown"/>
                <Button Grid.Column="1"
                        Classes="admin-row-icon-button"
                        Command="{Binding ClearSearchCommand}"
                        ToolTip.Tip="清空搜索">
                  <PathIcon Data="{Binding ClearSearchIconData}" Classes="admin-row-button-icon"/>
                </Button>
              </Grid>
            </Border>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
              <Grid RowDefinitions="Auto,Auto,*">
                <Grid ColumnDefinitions="220,200,*,108" ColumnSpacing="12" Margin="2,0,2,10">
                  <TextBlock Text="权限编码" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="1" Text="显示名称" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="2" Text="ID" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="3" Text="操作" Classes="admin-table-header"/>
                </Grid>

                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

                <Grid Grid.Row="2">
                  <ListBox ItemsSource="{Binding Items}"
                           SelectedItem="{Binding SelectedItem}"
                           Background="Transparent"
                           BorderThickness="0"
                           Margin="0,10,0,0"
                           IsVisible="{Binding HasPermissions}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="model:PermissionDto">
                        <Border Classes="admin-row-card" Margin="0,0,0,8" Padding="10">
                          <Grid ColumnDefinitions="220,200,*,108" ColumnSpacing="12">
                            <TextBlock Text="{Binding PermissionName}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Id}" Classes="admin-muted" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <WrapPanel Grid.Column="3" Orientation="Horizontal" ItemHeight="32" VerticalAlignment="Center">
                              <Button Classes="admin-row-icon-button"
                                      Command="{Binding DataContext.OpenEditDialogCommand, ElementName=Root}"
                                      CommandParameter="{Binding}"
                                      ToolTip.Tip="编辑权限"
                                      Margin="0,0,6,0">
                                <PathIcon Data="{Binding DataContext.EditIconData, ElementName=Root}" Classes="admin-row-button-icon"/>
                              </Button>
                              <Button Classes="admin-row-icon-button admin-danger"
                                      Command="{Binding DataContext.DeletePermissionCommand, ElementName=Root}"
                                      CommandParameter="{Binding}"
                                      ToolTip.Tip="删除权限">
                                <PathIcon Data="{Binding DataContext.DeleteIconData, ElementName=Root}" Classes="admin-row-button-icon"/>
                              </Button>
                            </WrapPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <Border Classes="info-card" HorizontalAlignment="Stretch" VerticalAlignment="Center" IsVisible="{Binding ShowPermissionsEmptyState}">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                      <TextBlock Text="暂无权限数据" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock Text="可调整搜索条件后重试，或点击右上角新增图标创建权限。" Classes="admin-hint" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="10">
                <Border Classes="admin-status-banner" Padding="10,8">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding PermissionCountText}" Classes="admin-hint"/>
                  </StackPanel>
                </Border>
                <Border Classes="admin-danger-banner" IsVisible="{Binding HasPendingDelete}" HorizontalAlignment="Left">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Text="{Binding DeleteConfirmationText}" Foreground="{DynamicResource TextOnAccentBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                      <Button Classes="admin-icon-button admin-danger-solid"
                              Command="{Binding ConfirmDeleteCommand}"
                              ToolTip.Tip="确认删除">
                        <PathIcon Data="{Binding ConfirmDeleteIconData}" Classes="admin-button-icon"/>
                      </Button>
                      <Button Classes="admin-icon-button"
                              Command="{Binding CancelDeleteCommand}"
                              ToolTip.Tip="取消删除">
                        <PathIcon Data="{Binding CancelIconData}" Classes="admin-button-icon"/>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <ComboBox Width="92"
                          ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding SelectedPageSize}"
                          HorizontalContentAlignment="Center"/>
                <Button Classes="admin-icon-button"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding CanGoPreviousPage}"
                        ToolTip.Tip="上一页">
                  <PathIcon Data="{Binding PreviousPageIconData}" Classes="admin-button-icon"/>
                </Button>
                <Border Classes="admin-pill admin-pill-muted" VerticalAlignment="Center">
                  <TextBlock Text="{Binding PaginationSummaryText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
                <Button Classes="admin-icon-button"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding CanGoNextPage}"
                        ToolTip.Tip="下一页">
                  <PathIcon Data="{Binding NextPageIconData}" Classes="admin-button-icon"/>
                </Button>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Classes="dialog-backdrop" IsVisible="{Binding IsPermissionDialogOpen}">
      <Grid>
        <Button Background="Transparent" BorderThickness="0" Command="{Binding ClosePermissionDialogCommand}"/>
        <Border Classes="dialog-card" Width="560" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding PermissionDialogTitle}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="用于维护权限名称与显示名称。" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
              </StackPanel>
              <Button Grid.Column="1" Classes="admin-button" Content="关闭" Command="{Binding ClosePermissionDialogCommand}"/>
            </Grid>

            <StackPanel Grid.Row="1" Spacing="6">
              <TextBlock Text="权限编码" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
              <TextBox Text="{Binding PermissionName}" Watermark="例如：users.view"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Spacing="6">
              <TextBlock Text="显示名称" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
              <TextBox Text="{Binding DisplayName}" Watermark="例如：查看用户"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Spacing="10">
              <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Classes="admin-button" Content="取消" Command="{Binding ClosePermissionDialogCommand}"/>
                <Button Classes="admin-button admin-danger" Content="删除所选" Command="{Binding DeleteCommand}"/>
                <Button Classes="admin-button admin-primary" Content="保存权限" Command="{Binding SaveCommand}"/>
              </StackPanel>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
