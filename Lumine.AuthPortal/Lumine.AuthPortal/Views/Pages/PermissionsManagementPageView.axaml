<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             xmlns:model="using:Lumine.AuthPortal.Models"
             x:Class="Lumine.AuthPortal.Views.Pages.PermissionsManagementPageView"
             x:Name="Root"
             x:DataType="vm:PermissionsManagementPageViewModel">
  <Grid>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        <Border Classes="admin-panel" Padding="18">
          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock Text="权限列表" Classes="admin-card-title"/>
                <TextBlock Text="维护权限编码、显示名称与后续页面/API 映射。" Classes="admin-hint"/>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Classes="admin-button" Content="刷新" Command="{Binding LoadCommand}"/>
                <Button Classes="admin-button admin-primary" Content="新增权限" Command="{Binding OpenCreateDialogCommand}"/>
                <Button Classes="admin-button" Content="编辑" Command="{Binding OpenEditDialogCommand}"/>
                <Button Classes="admin-button admin-danger" Content="删除" Command="{Binding DeleteCommand}" IsEnabled="{Binding HasSelectedPermission}"/>
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBox x:Name="PermissionSearchTextBox" Text="{Binding SearchKeyword}" Watermark="搜索权限名称 / 显示名" KeyDown="PermissionSearchTextBox_OnKeyDown"/>
              <Button Grid.Column="1" Classes="admin-button" Content="搜索" Command="{Binding SearchCommand}"/>
              <ComboBox Grid.Column="2" Width="96" ItemsSource="{Binding PageSizeOptions}" SelectedItem="{Binding SelectedPageSize}" HorizontalContentAlignment="Center"/>
              <Button Grid.Column="3" Classes="admin-button" Content="上一页" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding CanGoPreviousPage}"/>
              <Button Grid.Column="4" Classes="admin-button" Content="下一页" Command="{Binding NextPageCommand}" IsEnabled="{Binding CanGoNextPage}"/>
            </Grid>

            <Border Grid.Row="2" Classes="admin-status-banner">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
                <TextBlock Grid.Column="1" Text="{Binding PaginationSummaryText}" Foreground="{DynamicResource StatusInfoBrush}" VerticalAlignment="Center"/>
              </Grid>
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="1.55*,0.95*" ColumnSpacing="16">
              <Border Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
                <Grid RowDefinitions="Auto,Auto,*">
                  <Grid ColumnDefinitions="220,180,*,120" ColumnSpacing="12" Margin="2,0,2,10">
                    <TextBlock Text="权限编码" Classes="admin-table-header"/>
                    <TextBlock Grid.Column="1" Text="显示名称" Classes="admin-table-header"/>
                    <TextBlock Grid.Column="2" Text="ID" Classes="admin-table-header"/>
                    <TextBlock Grid.Column="3" Text="操作" Classes="admin-table-header"/>
                  </Grid>

                  <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

                  <ListBox Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="model:PermissionDto">
                        <Border Classes="admin-row-card" Margin="0,0,0,8" Padding="10">
                          <Grid ColumnDefinitions="220,180,*,120" ColumnSpacing="12">
                            <TextBlock Text="{Binding PermissionName}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Id}" Classes="admin-muted" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                              <Button Classes="admin-button admin-compact" Content="编辑" Command="{Binding DataContext.OpenEditDialogCommand, ElementName=Root}"/>
                              <Button Classes="admin-button admin-compact admin-danger"
                                      Content="删除"
                                      Command="{Binding DataContext.DeletePermissionCommand, ElementName=Root}"
                                      CommandParameter="{Binding}"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <StackPanel Grid.Column="1" Spacing="16">
                <Border Classes="info-card">
                  <StackPanel Spacing="8">
                    <TextBlock Text="当前选择" Classes="admin-card-title"/>
                    <TextBlock Text="{Binding EditorTitle}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PermissionCountText}" Classes="admin-hint"/>
                  </StackPanel>
                </Border>

                <Border Classes="info-card">
                  <StackPanel Spacing="8">
                    <TextBlock Text="命名建议" Classes="admin-card-title"/>
                    <TextBlock Text="推荐格式：资源.动作，例如 `users.view`、`roles.manage`、`clients.view`。" Classes="admin-hint" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>

            <Border Grid.Row="4" Classes="admin-danger-banner" IsVisible="{Binding HasPendingDelete}" HorizontalAlignment="Left">
              <StackPanel Spacing="10">
                <TextBlock Text="删除确认" Foreground="#FCA5A5" FontWeight="Bold"/>
                <TextBlock Text="{Binding DeleteConfirmationText}" Foreground="{DynamicResource TextOnAccentBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button Classes="admin-button admin-danger-solid" Content="确认删除" Command="{Binding ConfirmDeleteCommand}"/>
                  <Button Classes="admin-button" Content="取消" Command="{Binding CancelDeleteCommand}"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Classes="dialog-backdrop" IsVisible="{Binding IsPermissionDialogOpen}">
      <Grid>
        <Button Background="Transparent" BorderThickness="0" Command="{Binding ClosePermissionDialogCommand}"/>
        <Border Classes="dialog-card" Width="560" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding PermissionDialogTitle}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="用于维护权限名称与显示名称。" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
              </StackPanel>
              <Button Grid.Column="1" Classes="admin-button" Content="关闭" Command="{Binding ClosePermissionDialogCommand}"/>
            </Grid>

            <StackPanel Grid.Row="1" Spacing="6">
              <TextBlock Text="权限编码" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
              <TextBox Text="{Binding PermissionName}" Watermark="例如：users.view"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Spacing="6">
              <TextBlock Text="显示名称" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
              <TextBox Text="{Binding DisplayName}" Watermark="例如：查看用户"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Spacing="10">
              <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Classes="admin-button" Content="取消" Command="{Binding ClosePermissionDialogCommand}"/>
                <Button Classes="admin-button admin-danger" Content="删除所选" Command="{Binding DeleteCommand}"/>
                <Button Classes="admin-button admin-primary" Content="保存权限" Command="{Binding SaveCommand}"/>
              </StackPanel>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
