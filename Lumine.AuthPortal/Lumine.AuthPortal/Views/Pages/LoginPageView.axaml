<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.LoginPageView"
             x:DataType="vm:LoginPageViewModel">
  <UserControl.Styles>
    <Style Selector="TextBlock.form-label">
      <Setter Property="Foreground" Value="#CBD5E1"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TextBox.login-input">
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="Background" Value="#0F172A"/>
      <Setter Property="Foreground" Value="#F8FAFC"/>
      <Setter Property="BorderBrush" Value="#334155"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,8"/>
    </Style>
    <Style Selector="TextBox.login-input:focus">
      <Setter Property="BorderBrush" Value="#60A5FA"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*,Auto,*" Background="#0B1220">
    <Border Grid.Row="1"
            Grid.Column="1"
            MinWidth="340"
            MaxWidth="980"
            Background="#111827"
            BorderBrush="#1F2937"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
      <Grid ColumnDefinitions="1.05*,1.1*" MinHeight="560">
        <Border Background="#0F172A" Padding="34">
          <Grid RowDefinitions="Auto,*,Auto">
            <StackPanel Spacing="12">
              <TextBlock Text="Lumine AuthPortal"
                         Foreground="#F8FAFC"
                         FontSize="28"
                         FontWeight="Bold"/>
              <TextBlock Text="统一身份认证后台"
                         Foreground="#93C5FD"
                         FontSize="16"
                         FontWeight="SemiBold"/>
              <TextBlock Text="用于账号、角色、权限、OAuth 客户端和审计数据的集中管理。"
                         Foreground="#94A3B8"
                         TextWrapping="Wrap"
                         LineHeight="22"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="14">
              <Border Background="#1E293B" CornerRadius="8" Padding="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="OIDC / OAuth 2.1" Foreground="#F8FAFC" FontWeight="SemiBold"/>
                  <TextBlock Text="使用后台账号登录后进入管理控制台。"
                             Foreground="#94A3B8"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
              <Border Background="#172554" CornerRadius="8" Padding="16">
                <StackPanel Spacing="6">
                  <TextBlock Text="Admin Console" Foreground="#DBEAFE" FontWeight="SemiBold"/>
                  <TextBlock Text="登录成功后会根据当前用户权限展示可访问菜单。"
                             Foreground="#BFDBFE"
                             TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </StackPanel>

            <TextBlock Grid.Row="2"
                       Text="Lumine Identity Service"
                       Foreground="#64748B"
                       FontSize="12"/>
          </Grid>
        </Border>

        <Border Grid.Column="1" Background="#111827" Padding="40,38">
          <Grid RowDefinitions="Auto,*,Auto">
            <StackPanel Spacing="8">
              <TextBlock Text="登录后台"
                         FontSize="26"
                         FontWeight="Bold"
                         Foreground="#F9FAFB"/>
              <TextBlock Text="请输入本地调试或服务器环境中的后台账号。"
                         Foreground="#94A3B8"
                         TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        Spacing="16">
              <StackPanel Spacing="7">
                <TextBlock Text="用户名" Classes="form-label"/>
                <TextBox Text="{Binding UserName}"
                         Classes="login-input"
                         Watermark="admin"/>
              </StackPanel>

              <StackPanel Spacing="7">
                <TextBlock Text="密码" Classes="form-label"/>
                <TextBox Text="{Binding Password}"
                         Classes="login-input"
                         PasswordChar="*"
                         Watermark="请输入密码"/>
              </StackPanel>

              <Border Background="#0F172A"
                      BorderBrush="#1E293B"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="14">
                <StackPanel Spacing="12">
                  <TextBlock Text="授权参数" Foreground="#CBD5E1" FontWeight="SemiBold"/>
                  <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                    <StackPanel Grid.ColumnSpan="2" Spacing="6">
                      <TextBlock Text="Scope" Classes="form-label"/>
                      <TextBox Text="{Binding Scope}"
                               Classes="login-input"
                               Watermark="openid profile email roles permissions"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Spacing="6">
                      <TextBlock Text="Client ID" Classes="form-label"/>
                      <TextBox Text="{Binding ClientId}"
                               Classes="login-input"
                               Watermark="client_id"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                      <TextBlock Text="Nonce" Classes="form-label"/>
                      <TextBox Text="{Binding Nonce}"
                               Classes="login-input"
                               Watermark="nonce"/>
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>

              <Button Content="登录并进入后台"
                      Command="{Binding LoginCommand}"
                      Background="#2563EB"
                      Foreground="#F9FAFB"
                      BorderBrush="#60A5FA"
                      BorderThickness="1"
                      CornerRadius="8"
                      Padding="16,11"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Center"
                      FontWeight="SemiBold"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Background="#0F172A"
                    BorderBrush="#1E293B"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    MinHeight="46">
              <TextBlock Text="{Binding StatusMessage}"
                         Foreground="#CBD5E1"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center"/>
            </Border>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
