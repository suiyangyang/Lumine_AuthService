<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.LoginPageView"
             x:DataType="vm:LoginPageViewModel">
  <UserControl.Styles>
    <Style Selector="TextBlock.form-label">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TextBox.login-input">
      <Setter Property="MinHeight" Value="44"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="12,10"/>
      <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="SelectionBrush" Value="{DynamicResource SelectionBrush}"/>
    </Style>
    <Style Selector="TextBox.login-input /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
    </Style>
    <Style Selector="TextBox.login-input /template/ ScrollViewer#PART_ScrollViewer">
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
    </Style>
    <Style Selector="TextBox.login-input:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
    </Style>
    <Style Selector="TextBox.login-input:pointerover /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
    </Style>
    <Style Selector="TextBox.login-input:focus">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="TextBox.login-input:focus /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
    </Style>
    <Style Selector="TextBox.login-input:focus /template/ ScrollViewer#PART_ScrollViewer">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
    </Style>
    <Style Selector="Border.login-panel">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
    <Style Selector="Border.login-shell">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="32,30"/>
    </Style>
    <Style Selector="TextBox.password-input-field">
      <Setter Property="Padding" Value="12,10,42,10"/>
    </Style>
    <Style Selector="Button.password-visibility-button">
      <Setter Property="Width" Value="32"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="MinWidth" Value="32"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    </Style>
    <Style Selector="Button.password-visibility-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.password-visibility-button:pressed">
      <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="PathIcon.password-visibility-icon">
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="16"/>
    </Style>
    <Style Selector="Button.login-primary-action">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="16,11"/>
    </Style>
    <Style Selector="Button.login-primary-action /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:pointerover">
      <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:pointerover /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:pressed">
      <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:pressed /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextOnAccentBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:pressed /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderStrongBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:disabled">
      <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:disabled /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
    </Style>
    <Style Selector="Button.login-primary-action:disabled /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfaceSoftBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action">
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="14,10"/>
    </Style>
    <Style Selector="Button.login-secondary-action /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderStrongBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action:pointerover">
      <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action:pointerover /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action:pointerover /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderHoverBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action:pressed">
      <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action:pressed /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style Selector="Button.login-secondary-action:pressed /template/ Border#border">
      <Setter Property="Background" Value="{DynamicResource SurfacePressedBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
    </Style>
    <Style Selector="Button.login-link-action">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Foreground" Value="{DynamicResource LinkBrush}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="HorizontalContentAlignment" Value="Right"/>
    </Style>
    <Style Selector="Button.login-link-action:pointerover">
      <Setter Property="Foreground" Value="{DynamicResource LinkHoverBrush}"/>
    </Style>
    <Style Selector="Button.login-link-action:pressed">
      <Setter Property="Foreground" Value="{DynamicResource LinkPressedBrush}"/>
    </Style>
    <Style Selector="Border.login-status-banner">
      <Setter Property="Padding" Value="2,2,2,0"/>
    </Style>
    <Style Selector="Border.login-status-banner.status-error">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Border.login-status-banner.status-success">
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="TextBlock.login-status-text">
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBlock.login-status-text.status-error">
      <Setter Property="Foreground" Value="{DynamicResource DangerSoftForegroundBrush}"/>
    </Style>
    <Style Selector="TextBlock.login-status-text.status-success">
      <Setter Property="Foreground" Value="{DynamicResource SuccessBackgroundBrush}"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,Auto,*" ColumnDefinitions="*,Auto,*" Background="{DynamicResource AppBackgroundBrush}">
    <Border Grid.Row="1"
            Grid.Column="1"
            MinWidth="360"
            MaxWidth="560">
      <Border Classes="login-shell">
        <StackPanel Spacing="16">
          <TextBlock Text="登录"
                     FontSize="26"
                     FontWeight="Bold"
                     Foreground="{DynamicResource TextPrimaryBrush}"/>

          <StackPanel Spacing="12">
            <StackPanel Spacing="7">
              <TextBlock Text="用户名" Classes="form-label"/>
              <TextBox Text="{Binding UserName}"
                       Classes="login-input"
                       Watermark="请输入用户名"
                       IsEnabled="{Binding CanInteract}"
                       KeyDown="LoginInput_OnKeyDown"/>
            </StackPanel>

            <StackPanel Spacing="7">
              <TextBlock Text="密码" Classes="form-label"/>
              <Grid>
                <TextBox Text="{Binding Password}"
                         Classes="login-input password-input-field"
                         PasswordChar="{Binding PasswordMaskChar}"
                         Watermark="请输入密码"
                         IsEnabled="{Binding CanInteract}"
                         KeyDown="LoginInput_OnKeyDown"/>
                <Button Classes="password-visibility-button"
                        Command="{Binding TogglePasswordVisibilityCommand}"
                        IsEnabled="{Binding CanInteract}"
                        ToolTip.Tip="{Binding PasswordVisibilityToolTip}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                  <PathIcon Data="{Binding PasswordVisibilityIconData}"
                            Classes="password-visibility-icon"/>
                </Button>
              </Grid>
            </StackPanel>

            <Button Classes="login-primary-action"
                    Content="{Binding LoginButtonText}"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding CanInteract}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    FontWeight="SemiBold"/>

            <Button Classes="login-link-action"
                    Content="去注册"
                    Command="{Binding OpenRegisterCommand}"
                    IsEnabled="{Binding CanInteract}"
                    HorizontalAlignment="Right"/>

            <Button Classes="login-secondary-action"
                    Content="{Binding OidcToggleText}"
                    Command="{Binding ToggleOidcParametersCommand}"
                    IsEnabled="{Binding CanInteract}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"/>

            <StackPanel Spacing="12"
                        IsVisible="{Binding ShowOidcParameters}">
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <StackPanel Grid.ColumnSpan="2" Spacing="6">
                  <TextBlock Text="Scope" Classes="form-label"/>
                  <TextBox Text="{Binding Scope}"
                           Classes="login-input"
                           Watermark="openid profile email roles permissions"
                           IsEnabled="{Binding CanInteract}"
                           KeyDown="LoginInput_OnKeyDown"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Spacing="6">
                  <TextBlock Text="Client ID" Classes="form-label"/>
                  <TextBox Text="{Binding ClientId}"
                           Classes="login-input"
                           Watermark="client_id"
                           IsEnabled="{Binding CanInteract}"
                           KeyDown="LoginInput_OnKeyDown"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                  <TextBlock Text="Nonce" Classes="form-label"/>
                  <TextBox Text="{Binding Nonce}"
                           Classes="login-input"
                           Watermark="nonce"
                           IsEnabled="{Binding CanInteract}"
                           KeyDown="LoginInput_OnKeyDown"/>
                </StackPanel>
              </Grid>
            </StackPanel>

            <Border Classes="login-status-banner"
                    Classes.status-error="{Binding IsErrorMessage}"
                    Classes.status-success="{Binding IsSuccessMessage}"
                    IsVisible="{Binding HasStatusMessage}">
              <TextBlock Text="{Binding StatusMessage}"
                         Classes="login-status-text"
                         Classes.status-error="{Binding IsErrorMessage}"
                         Classes.status-success="{Binding IsSuccessMessage}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center"/>
            </Border>
          </StackPanel>
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</UserControl>
