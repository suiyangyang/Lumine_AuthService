<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             xmlns:model="using:Lumine.AuthPortal.Models"
             x:Class="Lumine.AuthPortal.Views.Pages.AuditLogsPageView"
             x:Name="Root"
             x:DataType="vm:AuditLogsPageViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16">
      <Border Classes="admin-panel" Padding="18">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="审计日志" Classes="admin-card-title"/>
              <TextBlock Text="查看登录、登出、授权确认、授权码签发、Token 换取与撤销等关键操作记录。" Classes="admin-hint"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Classes="admin-icon-button"
                      Command="{Binding ToggleSearchCommand}"
                      Click="ToggleSearchButton_OnClick"
                      ToolTip.Tip="搜索审计日志">
                <PathIcon Data="{Binding SearchIconData}" Classes="admin-button-icon"/>
              </Button>
              <Button Classes="admin-icon-button"
                      Command="{Binding LoadCommand}"
                      ToolTip.Tip="刷新列表">
                <PathIcon Data="{Binding RefreshIconData}" Classes="admin-button-icon"/>
              </Button>
            </StackPanel>
          </Grid>

          <Border Grid.Row="1"
                  Classes="admin-search-shell"
                  IsVisible="{Binding IsSearchVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
              <TextBox x:Name="SearchKeywordTextBox"
                       Classes="admin-search-input"
                       Text="{Binding SearchKeyword}"
                       Watermark="搜索分类、动作、操作者或结果，按 Enter 执行"
                       KeyDown="SearchKeywordTextBox_OnKeyDown"/>
              <Button Grid.Column="1"
                      Classes="admin-row-icon-button"
                      Command="{Binding ClearSearchCommand}"
                      ToolTip.Tip="清空搜索">
                <PathIcon Data="{Binding ClearSearchIconData}" Classes="admin-row-button-icon"/>
              </Button>
            </Grid>
          </Border>

          <Border Grid.Row="2" Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
            <Grid RowDefinitions="Auto,Auto,*">
              <Grid ColumnDefinitions="90,90,110,120,90,*" ColumnSpacing="12" Margin="2,0,2,10">
                <TextBlock Text="分类" Classes="admin-table-header"/>
                <TextBlock Grid.Column="1" Text="动作" Classes="admin-table-header"/>
                <TextBlock Grid.Column="2" Text="操作者" Classes="admin-table-header"/>
                <TextBlock Grid.Column="3" Text="目标" Classes="admin-table-header"/>
                <TextBlock Grid.Column="4" Text="结果" Classes="admin-table-header"/>
                <TextBlock Grid.Column="5" Text="详情" Classes="admin-table-header"/>
              </Grid>

              <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

              <Grid Grid.Row="2">
                <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Background="Transparent" BorderThickness="0" Margin="0,10,0,0" IsVisible="{Binding HasLogs}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="model:AuditLogEntryDto">
                      <Border Classes="admin-row-card" Margin="0,0,0,8" Padding="10">
                        <Grid ColumnDefinitions="90,90,110,120,90,*" ColumnSpacing="12">
                          <TextBlock Text="{Binding Category}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="1" Text="{Binding Action}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="2" Text="{Binding Actor}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="3" Text="{Binding Target}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="4" Text="{Binding Outcome}" Classes="admin-muted" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="5" Text="{Binding Details}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Border Classes="info-card" IsVisible="{Binding ShowEmptyState}" VerticalAlignment="Center">
                  <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="暂无审计记录" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="完成授权码申请、换取 Token 或撤销 Token 后，这里会出现对应记录。" Classes="admin-hint" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </Border>

          <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="10">
              <Border Classes="admin-status-banner" Padding="10,8">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
              </Border>
              <Border Classes="info-card" HorizontalAlignment="Left">
                <StackPanel Spacing="6">
                  <TextBlock Text="{Binding SelectedItem.Category, TargetNullValue=未选择记录}" Classes="admin-card-title"/>
                  <TextBlock Text="{Binding SelectedItem.Action, TargetNullValue=选择左侧记录查看详情}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                  <TextBlock Text="{Binding SelectedItem.Details}" Classes="admin-hint" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding SelectedItem.OccurredAtUtc, StringFormat=发生时间：{0:yyyy-MM-dd HH:mm:ss}, TargetNullValue=发生时间：--}" Classes="admin-hint"/>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <ComboBox Width="92"
                        ItemsSource="{Binding PageSizeOptions}"
                        SelectedItem="{Binding SelectedPageSize}"
                        HorizontalContentAlignment="Center"/>
              <Button Classes="admin-icon-button"
                      Command="{Binding PreviousPageCommand}"
                      IsEnabled="{Binding CanGoPreviousPage}"
                      ToolTip.Tip="上一页">
                <PathIcon Data="{Binding PreviousPageIconData}" Classes="admin-button-icon"/>
              </Button>
              <Border Classes="admin-pill admin-pill-muted" VerticalAlignment="Center">
                <TextBlock Text="{Binding PaginationSummaryText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Border>
              <Button Classes="admin-icon-button"
                      Command="{Binding NextPageCommand}"
                      IsEnabled="{Binding CanGoNextPage}"
                      ToolTip.Tip="下一页">
                <PathIcon Data="{Binding NextPageIconData}" Classes="admin-button-icon"/>
              </Button>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
