<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.ClientsManagementPageView"
             x:Name="Root"
             x:DataType="vm:ClientsManagementPageViewModel">
  <Grid>
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="16">
        <Border Classes="admin-panel" Padding="18">
          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock Text="OAuth 客户端列表" Classes="admin-card-title"/>
                <TextBlock Text="维护第三方系统接入所需的客户端参数、Scope 和回调地址。" Classes="admin-hint"/>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Classes="admin-button" Content="刷新" Command="{Binding LoadCommand}"/>
                <Button Classes="admin-button admin-primary" Content="新增客户端" Command="{Binding OpenCreateDialogCommand}"/>
                <Button Classes="admin-button" Content="编辑" Command="{Binding OpenEditDialogCommand}" IsEnabled="{Binding HasSelectedClient}"/>
                <Button Classes="admin-button admin-danger" Content="删除" Command="{Binding DeleteCommand}" IsEnabled="{Binding HasSelectedClient}"/>
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBox x:Name="ClientSearchTextBox" Text="{Binding SearchKeyword}" Watermark="搜索 ClientId / ClientName" KeyDown="ClientSearchTextBox_OnKeyDown"/>
              <Button Grid.Column="1" Classes="admin-button" Content="搜索" Command="{Binding SearchCommand}"/>
              <ComboBox Grid.Column="2" Width="96" ItemsSource="{Binding PageSizeOptions}" SelectedItem="{Binding SelectedPageSize}" HorizontalContentAlignment="Center"/>
              <Button Grid.Column="3" Classes="admin-button" Content="上一页" Command="{Binding PreviousPageCommand}" IsEnabled="{Binding CanGoPreviousPage}"/>
              <Button Grid.Column="4" Classes="admin-button" Content="下一页" Command="{Binding NextPageCommand}" IsEnabled="{Binding CanGoNextPage}"/>
            </Grid>

            <Border Grid.Row="2" Classes="admin-status-banner" Padding="14,10">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
                <TextBlock Grid.Column="1" Text="{Binding PaginationSummaryText}" Foreground="{DynamicResource StatusInfoBrush}" VerticalAlignment="Center"/>
              </Grid>
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="1.55*,0.95*" ColumnSpacing="16">
              <Border Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
                <Grid RowDefinitions="Auto,Auto,*">
                  <Grid ColumnDefinitions="160,150,110,*,90,130" ColumnSpacing="12" Margin="2,0,2,10">
                    <TextBlock Text="ClientId" Classes="admin-table-header"/>
                    <TextBlock Grid.Column="1" Text="名称" Classes="admin-table-header"/>
                    <TextBlock Grid.Column="2" Text="类型" Classes="admin-table-header"/>
                    <TextBlock Grid.Column="3" Text="Scope" Classes="admin-table-header"/>
                    <TextBlock Grid.Column="4" Text="状态" Classes="admin-table-header"/>
                    <TextBlock Grid.Column="5" Text="操作" Classes="admin-table-header"/>
                  </Grid>

                  <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

                  <ListBox Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Background="Transparent" BorderThickness="0" Margin="0,10,0,0">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                          <Grid ColumnDefinitions="160,150,110,*,90,130" ColumnSpacing="12">
                            <TextBlock Text="{Binding ClientId}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ClientName}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding ClientType}" Classes="admin-muted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding AllowedScopes}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding StatusText}" Classes="admin-muted" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8">
                              <Button Classes="admin-button admin-compact"
                                      Content="编辑"
                                      Command="{Binding DataContext.OpenEditDialogCommand, ElementName=Root}"
                                      CommandParameter="{Binding}"/>
                              <Button Classes="admin-button admin-compact admin-danger"
                                      Content="删除"
                                      Command="{Binding DataContext.DeleteClientCommand, ElementName=Root}"
                                      CommandParameter="{Binding}"/>
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
              </Border>

              <StackPanel Grid.Column="1" Spacing="16">
                <Border Classes="info-card">
                  <StackPanel Spacing="8">
                    <TextBlock Text="当前配置概览" Classes="admin-card-title"/>
                    <TextBlock Text="{Binding SelectedClientSummaryText}" Classes="admin-hint" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>

                <Border Classes="info-card">
                  <StackPanel Spacing="8">
                    <TextBlock Text="支持类型" Classes="admin-card-title"/>
                    <TextBlock Text="{Binding SupportedTypesText}" Classes="admin-hint" TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </StackPanel>
            </Grid>

            <Border Grid.Row="4" Classes="admin-danger-banner" IsVisible="{Binding HasPendingDelete}" HorizontalAlignment="Left">
              <StackPanel Spacing="10">
                <TextBlock Text="删除确认" Foreground="#FCA5A5" FontWeight="Bold"/>
                <TextBlock Text="{Binding DeleteConfirmationText}" Foreground="{DynamicResource TextOnAccentBrush}" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button Classes="admin-button admin-danger-solid" Content="确认删除" Command="{Binding ConfirmDeleteCommand}"/>
                  <Button Classes="admin-button" Content="取消" Command="{Binding CancelDeleteCommand}"/>
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Classes="dialog-backdrop" IsVisible="{Binding IsClientDialogOpen}">
      <Grid>
        <Button Background="Transparent" BorderThickness="0" Command="{Binding CloseClientDialogCommand}"/>
        <Border Classes="dialog-card" Width="760" MaxWidth="760" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding ClientDialogTitle}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="配置第三方系统接入所需的 OAuth 客户端参数。" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
              </StackPanel>
              <Button Grid.Column="1" Classes="admin-button" Content="关闭" Command="{Binding CloseClientDialogCommand}"/>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
              <StackPanel Spacing="6">
                <TextBlock Classes="admin-info-title" Text="ClientId"/>
                <TextBox Classes="admin-form-input" Text="{Binding ClientId}" Watermark="client_id"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="ClientName"/>
                <TextBox Classes="admin-form-input" Text="{Binding ClientName}" Watermark="客户端名称"/>
              </StackPanel>

              <StackPanel Grid.Row="1" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="GrantType / ClientType"/>
                <TextBox Classes="admin-form-input" Text="{Binding ClientType}" Watermark="public / confidential"/>
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="Scope"/>
                <TextBox Classes="admin-form-input" Text="{Binding AllowedScopesInput}" Watermark="scope，逗号分隔"/>
              </StackPanel>

              <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="RedirectUri"/>
                <TextBox Classes="admin-form-input" Text="{Binding RedirectUrisInput}" Watermark="redirect_uri，逗号分隔" AcceptsReturn="True" Height="72" TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="用于 / 描述"/>
                <TextBox Classes="admin-form-input" Text="{Binding Description}" Watermark="例如：第三方系统接入" AcceptsReturn="True" Height="72" TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="24" Margin="0,6,0,0">
                <CheckBox IsChecked="{Binding RequirePkce}" Content="要求 PKCE" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox IsChecked="{Binding IsActive}" Content="启用客户端" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
              <Button Classes="admin-button" Content="取消" Command="{Binding CloseClientDialogCommand}"/>
              <Button Classes="admin-button admin-primary" Content="保存" Command="{Binding SaveCommand}"/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
