<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.ClientsManagementPageView"
             x:Name="Root"
             x:DataType="vm:ClientsManagementPageViewModel">
  <Grid>
    <Border Classes="admin-panel" Padding="18">
      <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock Text="OAuth 客户端列表" Classes="admin-card-title"/>
                <TextBlock Text="维护第三方系统接入所需的客户端参数、Scope 和回调地址。" Classes="admin-hint"/>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="admin-icon-button"
                        Command="{Binding ToggleSearchCommand}"
                        Click="ToggleSearchButton_OnClick"
                        ToolTip.Tip="搜索客户端">
                  <PathIcon Data="{Binding SearchIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button"
                        Command="{Binding LoadCommand}"
                        ToolTip.Tip="刷新列表">
                  <PathIcon Data="{Binding RefreshIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button admin-primary"
                        Command="{Binding OpenCreateDialogCommand}"
                        ToolTip.Tip="新增客户端">
                  <PathIcon Data="{Binding AddIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button"
                        Command="{Binding OpenEditDialogCommand}"
                        IsEnabled="{Binding HasSelectedClient}"
                        ToolTip.Tip="编辑客户端">
                  <PathIcon Data="{Binding EditIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button admin-danger"
                        Command="{Binding DeleteCommand}"
                        IsEnabled="{Binding HasSelectedClient}"
                        ToolTip.Tip="删除客户端">
                  <PathIcon Data="{Binding DeleteIconData}" Classes="admin-button-icon"/>
                </Button>
              </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Classes="admin-search-shell"
                    IsVisible="{Binding IsSearchVisible}">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                <TextBox x:Name="ClientSearchTextBox"
                         Classes="admin-search-input"
                         Text="{Binding SearchKeyword}"
                         Watermark="搜索 ClientId 或 ClientName，按 Enter 执行"
                         KeyDown="ClientSearchTextBox_OnKeyDown"/>
                <Button Grid.Column="1"
                        Classes="admin-row-icon-button"
                        Command="{Binding ClearSearchCommand}"
                        ToolTip.Tip="清空搜索">
                  <PathIcon Data="{Binding ClearSearchIconData}" Classes="admin-row-button-icon"/>
                </Button>
              </Grid>
            </Border>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
              <Grid RowDefinitions="Auto,Auto,*">
                <Grid ColumnDefinitions="160,160,96,*,82,108" ColumnSpacing="12" Margin="2,0,2,10">
                  <TextBlock Text="ClientId" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="1" Text="名称" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="2" Text="类型" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="3" Text="Scope" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="4" Text="状态" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="5" Text="操作" Classes="admin-table-header"/>
                </Grid>

                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

                <Grid Grid.Row="2">
                  <ListBox ItemsSource="{Binding Items}"
                           SelectedItem="{Binding SelectedItem}"
                           Background="Transparent"
                           BorderThickness="0"
                           Margin="0,10,0,0"
                           IsVisible="{Binding HasClients}">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="admin-row-card" Margin="0,0,0,8" Padding="10">
                          <Grid ColumnDefinitions="160,160,96,*,82,108" ColumnSpacing="12">
                            <TextBlock Text="{Binding ClientId}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ClientName}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding ClientType}" Classes="admin-muted" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding AllowedScopesDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="4" Text="{Binding StatusText}" Classes="admin-muted" VerticalAlignment="Center"/>
                            <WrapPanel Grid.Column="5" Orientation="Horizontal" ItemHeight="32" VerticalAlignment="Center">
                              <Button Classes="admin-row-icon-button"
                                      Command="{Binding DataContext.OpenEditDialogCommand, ElementName=Root}"
                                      CommandParameter="{Binding}"
                                      ToolTip.Tip="编辑客户端"
                                      Margin="0,0,6,0">
                                <PathIcon Data="{Binding DataContext.EditIconData, ElementName=Root}" Classes="admin-row-button-icon"/>
                              </Button>
                              <Button Classes="admin-row-icon-button admin-danger"
                                      Command="{Binding DataContext.DeleteClientCommand, ElementName=Root}"
                                      CommandParameter="{Binding}"
                                      ToolTip.Tip="删除客户端">
                                <PathIcon Data="{Binding DataContext.DeleteIconData, ElementName=Root}" Classes="admin-row-button-icon"/>
                              </Button>
                            </WrapPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <Border Classes="info-card" HorizontalAlignment="Stretch" VerticalAlignment="Center" IsVisible="{Binding ShowClientsEmptyState}">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                      <TextBlock Text="暂无客户端数据" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock Text="可调整搜索条件后重试，或点击右上角新增图标创建客户端。" Classes="admin-hint" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="10">
                <Border Classes="admin-status-banner" Padding="10,8">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding ClientCountText}" Classes="admin-hint"/>
                  </StackPanel>
                </Border>
                <Border Classes="admin-danger-banner" IsVisible="{Binding HasPendingDelete}" HorizontalAlignment="Left">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Text="{Binding DeleteConfirmationText}" Foreground="{DynamicResource TextOnAccentBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                      <Button Classes="admin-icon-button admin-danger-solid" Command="{Binding ConfirmDeleteCommand}" ToolTip.Tip="确认删除">
                        <PathIcon Data="{Binding ConfirmDeleteIconData}" Classes="admin-button-icon"/>
                      </Button>
                      <Button Classes="admin-icon-button" Command="{Binding CancelDeleteCommand}" ToolTip.Tip="取消删除">
                        <PathIcon Data="{Binding CancelIconData}" Classes="admin-button-icon"/>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="admin-icon-button"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding CanGoPreviousPage}"
                        ToolTip.Tip="上一页">
                  <PathIcon Data="{Binding PreviousPageIconData}" Classes="admin-button-icon"/>
                </Button>
                <Border Classes="admin-pill admin-pill-muted" VerticalAlignment="Center">
                  <TextBlock Text="{Binding PaginationSummaryText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
                <Button Classes="admin-icon-button"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding CanGoNextPage}"
                        ToolTip.Tip="下一页">
                  <PathIcon Data="{Binding NextPageIconData}" Classes="admin-button-icon"/>
                </Button>
              </StackPanel>
            </Grid>
      </Grid>
    </Border>

    <Border Classes="dialog-backdrop" IsVisible="{Binding IsClientDialogOpen}">
      <Grid>
        <Button Background="Transparent" BorderThickness="0" Command="{Binding CloseClientDialogCommand}"/>
        <Border Classes="dialog-card" Width="760" MaxWidth="760" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding ClientDialogTitle}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="配置第三方系统接入所需的 OAuth 客户端参数。" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap"/>
              </StackPanel>
              <Button Grid.Column="1" Classes="admin-button" Content="关闭" Command="{Binding CloseClientDialogCommand}"/>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
              <StackPanel Spacing="6">
                <TextBlock Classes="admin-info-title" Text="ClientId"/>
                <TextBox Classes="admin-form-input" Text="{Binding ClientId}" Watermark="client_id"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="ClientName"/>
                <TextBox Classes="admin-form-input" Text="{Binding ClientName}" Watermark="客户端名称"/>
              </StackPanel>

              <StackPanel Grid.Row="1" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="GrantType / ClientType"/>
                <TextBox Classes="admin-form-input" Text="{Binding ClientType}" Watermark="public / confidential"/>
              </StackPanel>
              <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="Scope"/>
                <TextBox Classes="admin-form-input" Text="{Binding AllowedScopesInput}" Watermark="scope，逗号分隔"/>
              </StackPanel>

              <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="RedirectUri"/>
                <TextBox Classes="admin-form-input" Text="{Binding RedirectUrisInput}" Watermark="redirect_uri，逗号分隔" AcceptsReturn="True" Height="72" TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Spacing="6">
                <TextBlock Classes="admin-info-title" Text="用于 / 描述"/>
                <TextBox Classes="admin-form-input" Text="{Binding Description}" Watermark="例如：第三方系统接入" AcceptsReturn="True" Height="72" TextWrapping="Wrap"/>
              </StackPanel>

              <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="24" Margin="0,6,0,0">
                <CheckBox IsChecked="{Binding RequirePkce}" Content="要求 PKCE" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <CheckBox IsChecked="{Binding IsActive}" Content="启用客户端" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
              <Button Classes="admin-button" Content="取消" Command="{Binding CloseClientDialogCommand}"/>
              <Button Classes="admin-button admin-primary" Content="保存" Command="{Binding SaveCommand}"/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
