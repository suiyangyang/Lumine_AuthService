<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             xmlns:model="using:Lumine.AuthPortal.Models"
             x:Class="Lumine.AuthPortal.Views.Pages.MenusManagementPageView"
             x:DataType="vm:MenusManagementPageViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16">
      <Border Classes="admin-panel">
        <StackPanel Spacing="14">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="菜单管理" Classes="admin-card-title"/>
              <TextBlock Text="查看登录后左侧菜单的顺序、路由、权限绑定和当前实现状态。" Classes="admin-hint"/>
            </StackPanel>
            <Button Grid.Column="1" Classes="admin-button" Content="刷新" Command="{Binding LoadCommand}"/>
          </Grid>

          <Border Classes="admin-status-banner">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
          </Border>

          <Grid ColumnDefinitions="1.5*,0.9*" ColumnSpacing="16">
            <Border Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
              <Grid RowDefinitions="Auto,Auto,*">
                <Grid ColumnDefinitions="60,120,120,170,90,*" ColumnSpacing="12" Margin="2,0,2,10">
                  <TextBlock Text="顺序" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="1" Text="菜单" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="2" Text="分组" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="3" Text="路由" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="4" Text="状态" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="5" Text="说明" Classes="admin-table-header"/>
                </Grid>

                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

                <ListBox Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Background="Transparent" BorderThickness="0" Margin="0,10,0,0" IsVisible="{Binding HasMenus}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="model:PortalMenuItemDto">
                      <Border Classes="admin-row-card" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="60,120,120,170,90,*" ColumnSpacing="12">
                          <TextBlock Text="{Binding Order}" Classes="admin-muted" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="2" Text="{Binding Section}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="3" Text="{Binding Route}" Classes="admin-muted" VerticalAlignment="Center"/>
                          <Border Grid.Column="4" Classes="admin-pill admin-pill-success" HorizontalAlignment="Left" VerticalAlignment="Center" IsVisible="{Binding IsImplemented}">
                            <TextBlock Text="已实现" Foreground="#ECFDF5" FontSize="12"/>
                          </Border>
                          <TextBlock Grid.Column="5" Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <Border Grid.Column="1" Classes="info-card">
              <StackPanel Spacing="10">
                <TextBlock Text="权限绑定" Classes="admin-card-title"/>
                <TextBlock Text="{Binding SelectedItem.Title, TargetNullValue=未选择菜单}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding PermissionSummaryText}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding SelectedItem.Description, TargetNullValue=选择左侧菜单项后查看说明}" Classes="admin-hint" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
