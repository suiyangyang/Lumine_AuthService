<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.SystemSettingsPageView"
             x:DataType="vm:SystemSettingsPageViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16">
      <Border Classes="admin-panel">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="#F9FAFB"/>
          <TextBlock Text="{Binding Description}" Foreground="#CBD5E1" TextWrapping="Wrap"/>
          <Border Classes="admin-status-banner">
            <TextBlock Text="{Binding DefaultManagementPageSize, StringFormat=当前后台列表默认分页：{0} 条 / 页}"
                       Foreground="#BFDBFE"/>
          </Border>
        </StackPanel>
      </Border>

      <ItemsControl ItemsSource="{Binding SettingCards}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="3"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SystemSettingCardItemViewModel">
            <Border Classes="admin-panel" Margin="0,0,12,0">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding Title}" Classes="admin-hint"/>
                <TextBlock Text="{Binding Value}" FontSize="22" FontWeight="Bold" Foreground="#F9FAFB"/>
                <TextBlock Text="{Binding Description}" Foreground="#CBD5E1" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <ItemsControl ItemsSource="{Binding SettingGroups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SystemSettingGroupItemViewModel">
            <Border Classes="admin-panel" Margin="0,0,0,14">
              <StackPanel Spacing="12">
                <TextBlock Text="{Binding Title}" Classes="admin-card-title"/>
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#0F172A" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                        <TextBlock Text="{Binding .}" Foreground="#D1D5DB"/>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
