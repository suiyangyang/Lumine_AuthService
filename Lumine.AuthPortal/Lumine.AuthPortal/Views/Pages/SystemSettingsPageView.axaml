<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.SystemSettingsPageView"
             x:Name="Root"
             x:DataType="vm:SystemSettingsPageViewModel">
  <UserControl.Styles>
    <Style Selector="Border.theme-option-card">
      <Setter Property="Background" Value="{DynamicResource SurfacePanelBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="16"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>
    <Style Selector="Border.theme-option-card.theme-option-selected">
      <Setter Property="BorderBrush" Value="{DynamicResource BorderActiveBrush}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="Border.theme-preview-card">
      <Setter Property="Background" Value="{DynamicResource SurfaceInsetBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="Padding" Value="14"/>
    </Style>
    <Style Selector="Border.theme-preview-sample">
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style Selector="TextBlock.theme-preview-column">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
      <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.theme-preview-row">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
  </UserControl.Styles>
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16">
      <Border Classes="admin-panel">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
          <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
          <Border Classes="admin-status-banner">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding CurrentThemeLabel, StringFormat=当前主题：{0}}"
                         Foreground="{DynamicResource StatusInfoBrush}"/>
              <TextBlock Text="{Binding DefaultManagementPageSize, StringFormat=后台列表默认分页：{0} 条 / 页}"
                         Foreground="{DynamicResource StatusInfoBrush}"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="admin-panel">
        <StackPanel Spacing="14">
          <TextBlock Text="界面主题" Classes="admin-card-title"/>
          <TextBlock Text="可在 Fluent Light 与 VS Code Dark 之间切换，所有后台页面将同步应用主题资源。"
                     Classes="admin-info-body"/>

          <ItemsControl ItemsSource="{Binding ThemeOptions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="2"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ThemeOptionCardViewModel">
                <Border Classes="theme-option-card"
                        Classes.theme-option-selected="{Binding IsSelected}">
                  <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                      <StackPanel Spacing="4">
                        <TextBlock Text="{Binding DisplayName}" Classes="admin-section-title"/>
                        <TextBlock Text="{Binding Description}" Classes="admin-info-body"/>
                      </StackPanel>
                      <Button Grid.Column="1"
                              Classes="admin-button admin-primary admin-compact"
                              Content="{Binding ActionText}"
                              Command="{Binding DataContext.ApplyThemeCommand, ElementName=Root}"
                              CommandParameter="{Binding}"
                              IsEnabled="{Binding CanApply}"/>
                    </Grid>

                    <Border CornerRadius="12"
                            Padding="12"
                            Background="{Binding PreviewBackground}">
                      <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="1.2*,0.8*" RowSpacing="10" ColumnSpacing="10">
                        <Border Background="{Binding PreviewSurface}" CornerRadius="10" Height="52" Padding="10">
                          <StackPanel Spacing="4">
                            <Border Width="46" Height="6" CornerRadius="3" Background="{Binding PreviewAccent}" HorizontalAlignment="Left"/>
                            <Border Width="84" Height="6" CornerRadius="3" Background="{Binding PreviewText}" Opacity="0.85" HorizontalAlignment="Left"/>
                          </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{Binding PreviewSurface}" CornerRadius="10" Height="52" Padding="10">
                          <StackPanel Spacing="6" HorizontalAlignment="Right">
                            <Border Width="34" Height="6" CornerRadius="3" Background="{Binding PreviewText}" Opacity="0.65"/>
                            <Border Width="52" Height="6" CornerRadius="3" Background="{Binding PreviewAccent}"/>
                          </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{Binding PreviewSurface}" CornerRadius="10" Height="36" Padding="10">
                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Border Width="16" Height="16" CornerRadius="8" Background="{Binding PreviewAccent}" VerticalAlignment="Center"/>
                            <Border Grid.Column="1" Width="110" Height="6" CornerRadius="3" Background="{Binding PreviewText}" Opacity="0.7" VerticalAlignment="Center"/>
                          </Grid>
                        </Border>
                      </Grid>
                    </Border>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Classes="admin-panel">
        <StackPanel Spacing="14">
          <TextBlock Text="主题状态预览" Classes="admin-card-title"/>
          <TextBlock Text="对照 VS Code Dark 的层级与对比关系，集中展示常用后台控件在 Default、Hover、Pressed、Disabled 下的视觉状态。"
                     Classes="admin-info-body"/>
          <TextBlock Text="输入类控件以 Focus 代替 Pressed，导航项以 Selected 代替 Pressed，用于检查暗色主题下文本、边框和背景是否保持清晰。"
                     Classes="admin-hint"/>

          <Grid ColumnDefinitions="1.3*,1*,1*,1*,1*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                ColumnSpacing="12" RowSpacing="10">
            <TextBlock Grid.Column="1" Text="Default" Classes="theme-preview-column"/>
            <TextBlock Grid.Column="2" Text="Hover" Classes="theme-preview-column"/>
            <TextBlock Grid.Column="3" Text="Pressed / Focused" Classes="theme-preview-column"/>
            <TextBlock Grid.Column="4" Text="Disabled / Selected" Classes="theme-preview-column"/>

            <TextBlock Grid.Row="1" Text="主按钮" Classes="theme-preview-row"/>
            <Border Grid.Row="1" Grid.Column="1" Classes="theme-preview-sample"
                    Background="{DynamicResource AccentBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}">
              <TextBlock Text="确认操作" Foreground="{DynamicResource TextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="2" Classes="theme-preview-sample"
                    Background="{DynamicResource AccentHoverBrush}"
                    BorderBrush="{DynamicResource AccentBorderStrongBrush}">
              <TextBlock Text="悬停中" Foreground="{DynamicResource TextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="3" Classes="theme-preview-sample"
                    Background="{DynamicResource AccentPressedBrush}"
                    BorderBrush="{DynamicResource AccentBorderStrongBrush}">
              <TextBlock Text="按下中" Foreground="{DynamicResource TextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="1" Grid.Column="4" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <TextBlock Text="不可用" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Grid.Row="2" Text="次按钮" Classes="theme-preview-row"/>
            <Border Grid.Row="2" Grid.Column="1" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceRaisedBrush}"
                    BorderBrush="{DynamicResource BorderStrongBrush}">
              <TextBlock Text="次级操作" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="2" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceHoverBrush}"
                    BorderBrush="{DynamicResource BorderHoverBrush}">
              <TextBlock Text="悬停中" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="3" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfacePressedBrush}"
                    BorderBrush="{DynamicResource BorderHoverBrush}">
              <TextBlock Text="按下中" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="2" Grid.Column="4" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <TextBlock Text="不可用" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Grid.Row="3" Text="危险按钮" Classes="theme-preview-row"/>
            <Border Grid.Row="3" Grid.Column="1" Classes="theme-preview-sample"
                    Background="{DynamicResource DangerSoftBackgroundBrush}"
                    BorderBrush="{DynamicResource DangerSoftBorderBrush}">
              <TextBlock Text="删除项目" Foreground="{DynamicResource DangerSoftForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="3" Grid.Column="2" Classes="theme-preview-sample"
                    Background="{DynamicResource DangerSoftHoverBackgroundBrush}"
                    BorderBrush="{DynamicResource DangerSoftHoverBorderBrush}">
              <TextBlock Text="悬停中" Foreground="{DynamicResource DangerSoftHoverForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="3" Grid.Column="3" Classes="theme-preview-sample"
                    Background="{DynamicResource DangerSoftPressedBackgroundBrush}"
                    BorderBrush="{DynamicResource DangerSoftPressedBorderBrush}">
              <TextBlock Text="按下中" Foreground="{DynamicResource DangerSoftPressedForegroundBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="3" Grid.Column="4" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <TextBlock Text="不可用" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Grid.Row="4" Text="输入框" Classes="theme-preview-row"/>
            <Border Grid.Row="4" Grid.Column="1" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    BorderBrush="{DynamicResource BorderStrongBrush}">
              <TextBlock Text="默认输入内容" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="4" Grid.Column="2" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceSoftBrush}"
                    BorderBrush="{DynamicResource BorderHoverBrush}">
              <TextBlock Text="Hover 输入内容" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="4" Grid.Column="3" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfacePanelBrush}"
                    BorderBrush="{DynamicResource BorderActiveBrush}">
              <TextBlock Text="Focused 输入内容" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="4" Grid.Column="4" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceSoftBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <TextBlock Text="Disabled 输入内容" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Grid.Row="5" Text="下拉框" Classes="theme-preview-row"/>
            <Border Grid.Row="5" Grid.Column="1" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    BorderBrush="{DynamicResource BorderStrongBrush}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="10 条 / 页" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="▾" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              </Grid>
            </Border>
            <Border Grid.Row="5" Grid.Column="2" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    BorderBrush="{DynamicResource BorderHoverBrush}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Hover 选项" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="▾" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              </Grid>
            </Border>
            <Border Grid.Row="5" Grid.Column="3" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    BorderBrush="{DynamicResource BorderActiveBrush}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Focused 选项" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="▾" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
              </Grid>
            </Border>
            <Border Grid.Row="5" Grid.Column="4" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceSoftBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Disabled 选项" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="▾" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
              </Grid>
            </Border>

            <TextBlock Grid.Row="6" Text="列表 / 导航" Classes="theme-preview-row"/>
            <Border Grid.Row="6" Grid.Column="1" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfacePanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <TextBlock Text="默认菜单项" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="6" Grid.Column="2" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceHoverBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <TextBlock Text="Hover 菜单项" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="6" Grid.Column="3" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceSelectedHoverBrush}"
                    BorderBrush="{DynamicResource BorderActiveBrush}">
              <TextBlock Text="Active 菜单项" Foreground="{DynamicResource TextOnSelectedBrush}" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="6" Grid.Column="4" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfacePanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <TextBlock Text="Muted 菜单项" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
            </Border>

            <TextBlock Grid.Row="7" Text="表格行操作" Classes="theme-preview-row"/>
            <Border Grid.Row="7" Grid.Column="1" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceRaisedBrush}"
                    BorderBrush="{DynamicResource BorderStrongBrush}">
              <TextBlock Text="编辑 / 查看" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="7" Grid.Column="2" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceHoverBrush}"
                    BorderBrush="{DynamicResource BorderActiveBrush}">
              <TextBlock Text="Hover 操作" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="7" Grid.Column="3" Classes="theme-preview-sample"
                    Background="{DynamicResource DangerSolidHoverBackgroundBrush}"
                    BorderBrush="{DynamicResource DangerSolidBorderBrush}">
              <TextBlock Text="危险操作" Foreground="{DynamicResource TextOnAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.Row="7" Grid.Column="4" Classes="theme-preview-sample"
                    Background="{DynamicResource SurfaceInsetBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}">
              <TextBlock Text="不可用" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

      <ItemsControl ItemsSource="{Binding SettingCards}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="3"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SystemSettingCardItemViewModel">
            <Border Classes="admin-panel" Margin="0,0,12,0">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding Title}" Classes="admin-hint"/>
                <TextBlock Text="{Binding Value}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <ItemsControl ItemsSource="{Binding SettingGroups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:SystemSettingGroupItemViewModel">
            <Border Classes="admin-panel" Margin="0,0,0,14">
              <StackPanel Spacing="12">
                <TextBlock Text="{Binding Title}" Classes="admin-card-title"/>
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                        <TextBlock Text="{Binding .}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </ScrollViewer>
</UserControl>
