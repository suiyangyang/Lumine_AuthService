<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             xmlns:model="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.RolesManagementPageView"
             x:Name="Root"
             x:DataType="vm:RolesManagementPageViewModel">
  <Grid>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="16">
        <Border Classes="admin-panel" Padding="18">
          <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
              <StackPanel Spacing="4">
                <TextBlock Text="角色列表" Classes="admin-card-title"/>
                <TextBlock Text="维护角色定义、权限数量和分配关系。" Classes="admin-hint"/>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Classes="admin-icon-button"
                        Command="{Binding ToggleSearchCommand}"
                        Click="ToggleSearchButton_OnClick"
                        ToolTip.Tip="搜索角色">
                  <PathIcon Data="{Binding SearchIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button"
                        Command="{Binding LoadCommand}"
                        ToolTip.Tip="刷新列表">
                  <PathIcon Data="{Binding RefreshIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button admin-primary"
                        Command="{Binding OpenCreateDialogCommand}"
                        ToolTip.Tip="新增角色">
                  <PathIcon Data="{Binding AddIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button"
                        Command="{Binding OpenEditDialogCommand}"
                        IsEnabled="{Binding HasSelectedRole}"
                        ToolTip.Tip="编辑角色">
                  <PathIcon Data="{Binding EditIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button"
                        Command="{Binding OpenAssignPermissionsDialogCommand}"
                        IsEnabled="{Binding HasSelectedRole}"
                        ToolTip.Tip="分配权限">
                  <PathIcon Data="{Binding AssignPermissionsIconData}" Classes="admin-button-icon"/>
                </Button>
                <Button Classes="admin-icon-button admin-danger"
                        Command="{Binding DeleteCommand}"
                        IsEnabled="{Binding HasSelectedRole}"
                        ToolTip.Tip="删除角色">
                  <PathIcon Data="{Binding DeleteIconData}" Classes="admin-button-icon"/>
                </Button>
              </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Classes="admin-search-shell"
                    IsVisible="{Binding IsSearchVisible}">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                <TextBox x:Name="RoleSearchTextBox"
                         Classes="admin-search-input"
                         Text="{Binding SearchKeyword}"
                         Watermark="搜索角色名称，按 Enter 执行"
                         KeyDown="RoleSearchTextBox_OnKeyDown"/>
                <Button Grid.Column="1"
                        Classes="admin-row-icon-button"
                        Command="{Binding ClearSearchCommand}"
                        ToolTip.Tip="清空搜索">
                  <PathIcon Data="{Binding ClearSearchIconData}" Classes="admin-row-button-icon"/>
                </Button>
              </Grid>
            </Border>

            <Border Grid.Row="2" Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
              <Grid RowDefinitions="Auto,Auto,*">
                <Grid ColumnDefinitions="170,170,*,90,120,144" ColumnSpacing="12" Margin="2,0,2,10">
                  <TextBlock Text="ID" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="1" Text="角色名称" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="2" Text="权限摘要" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="3" Text="权限数" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="4" Text="创建时间" Classes="admin-table-header"/>
                  <TextBlock Grid.Column="5" Text="操作" Classes="admin-table-header"/>
                </Grid>

                <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

                <Grid Grid.Row="2">
                  <ListBox ItemsSource="{Binding RoleRows}"
                           SelectedItem="{Binding SelectedRoleRow}"
                           Background="Transparent"
                           BorderThickness="0"
                           Margin="0,10,0,0"
                           IsVisible="{Binding HasRoles}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="model:RoleTableRowViewModel">
                        <Border Classes="admin-row-card" Margin="0,0,0,8" Padding="10">
                          <Grid ColumnDefinitions="170,170,*,90,120,144" ColumnSpacing="12">
                            <TextBlock Text="{Binding Id}" Classes="admin-muted" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock Grid.Column="3" Text="{Binding PermissionCount}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding CreatedTimeText}" Classes="admin-muted" VerticalAlignment="Center"/>
                            <WrapPanel Grid.Column="5" Orientation="Horizontal" ItemHeight="32" VerticalAlignment="Center">
                              <Button Classes="admin-row-icon-button"
                                      Command="{Binding DataContext.OpenEditDialogCommand, ElementName=Root}"
                                      CommandParameter="{Binding Source}"
                                      ToolTip.Tip="编辑角色"
                                      Margin="0,0,6,0">
                                <PathIcon Data="{Binding DataContext.EditIconData, ElementName=Root}" Classes="admin-row-button-icon"/>
                              </Button>
                              <Button Classes="admin-row-icon-button"
                                      Command="{Binding DataContext.OpenAssignPermissionsDialogCommand, ElementName=Root}"
                                      CommandParameter="{Binding Source}"
                                      ToolTip.Tip="分配权限"
                                      Margin="0,0,6,0">
                                <PathIcon Data="{Binding DataContext.AssignPermissionsIconData, ElementName=Root}" Classes="admin-row-button-icon"/>
                              </Button>
                              <Button Classes="admin-row-icon-button admin-danger"
                                      Command="{Binding DataContext.DeleteRoleCommand, ElementName=Root}"
                                      CommandParameter="{Binding Source}"
                                      ToolTip.Tip="删除角色">
                                <PathIcon Data="{Binding DataContext.DeleteIconData, ElementName=Root}" Classes="admin-row-button-icon"/>
                              </Button>
                            </WrapPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <Border Classes="info-card" HorizontalAlignment="Stretch" VerticalAlignment="Center" IsVisible="{Binding ShowRolesEmptyState}">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                      <TextBlock Text="暂无角色数据" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock Text="可调整搜索条件后重试，或点击右上角新增图标创建角色。" Classes="admin-hint" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="10">
                <Border Classes="admin-status-banner" Padding="10,8">
                  <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
                </Border>
                <Border Classes="admin-danger-banner" IsVisible="{Binding HasPendingDelete}" HorizontalAlignment="Left">
                  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <TextBlock Text="{Binding DeleteConfirmationText}" Foreground="{DynamicResource TextOnAccentBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                      <Button Classes="admin-icon-button admin-danger-solid"
                              Command="{Binding ConfirmDeleteCommand}"
                              ToolTip.Tip="确认删除">
                        <PathIcon Data="{Binding ConfirmDeleteIconData}" Classes="admin-button-icon"/>
                      </Button>
                      <Button Classes="admin-icon-button"
                              Command="{Binding CancelDeleteCommand}"
                              ToolTip.Tip="取消删除">
                        <PathIcon Data="{Binding CancelIconData}" Classes="admin-button-icon"/>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Border>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <ComboBox Width="92"
                          ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding SelectedPageSize}"
                          HorizontalContentAlignment="Center"/>
                <Button Classes="admin-icon-button"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding CanGoPreviousPage}"
                        ToolTip.Tip="上一页">
                  <PathIcon Data="{Binding PreviousPageIconData}" Classes="admin-button-icon"/>
                </Button>
                <Border Classes="admin-pill admin-pill-muted" VerticalAlignment="Center">
                  <TextBlock Text="{Binding PaginationSummaryText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
                <Button Classes="admin-icon-button"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding CanGoNextPage}"
                        ToolTip.Tip="下一页">
                  <PathIcon Data="{Binding NextPageIconData}" Classes="admin-button-icon"/>
                </Button>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Classes="dialog-backdrop" IsVisible="{Binding IsRoleDialogOpen}">
      <Grid>
        <Button Background="Transparent" BorderThickness="0" Command="{Binding CloseRoleDialogCommand}"/>
        <Border Classes="dialog-card" Width="760" MaxHeight="760" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding RoleDialogTitle}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding CurrentRoleIdentity, StringFormat=当前角色：{0}}" Classes="admin-hint" TextWrapping="Wrap"/>
              </StackPanel>
              <Button Grid.Column="1" Classes="admin-button" Content="关闭" Command="{Binding CloseRoleDialogCommand}"/>
            </Grid>

            <StackPanel Grid.Row="1" Spacing="8">
              <TextBlock Text="角色名称" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
              <TextBox Text="{Binding Name}" Watermark="请输入角色名称"/>
            </StackPanel>

            <Border Grid.Row="2" Classes="info-card">
              <StackPanel Spacing="4">
                <TextBlock Text="已选权限" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding SelectedPermissionSummary}" Classes="admin-hint" TextWrapping="Wrap" MaxHeight="72"/>
                <TextBlock Text="{Binding SelectedPermissionCount, StringFormat=当前勾选 {0} 项权限}" Classes="admin-hint"/>
              </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
              <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding PermissionGroups}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:RolePermissionGroupNodeViewModel">
                      <Expander IsExpanded="True" Margin="0,0,0,10">
                        <Expander.Header>
                          <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <CheckBox IsThreeState="True" IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                              <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                              <TextBlock Text="{Binding Hint}" Classes="admin-hint"/>
                            </StackPanel>
                            <Border Grid.Column="2" Classes="admin-pill admin-pill-muted" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                          </Grid>
                        </Expander.Header>

                        <ItemsControl ItemsSource="{Binding Items}" Margin="10,10,0,0">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:RolePermissionLeafNodeViewModel">
                              <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                  <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
                                  <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DisplayName}" Classes="admin-hint"/>
                                  </StackPanel>
                                  <TextBlock Grid.Column="2" Text="{Binding PermissionName}" Classes="admin-muted" VerticalAlignment="Center"/>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Expander>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="4" Spacing="10">
              <TextBlock Text="{Binding StatusMessage}" Classes="admin-hint" TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Classes="admin-button" Content="取消" Command="{Binding CloseRoleDialogCommand}"/>
                <Button Classes="admin-button admin-primary" Content="保存角色" Command="{Binding SaveCommand}"/>
                <Button Classes="admin-button admin-success" Content="保存权限" Command="{Binding AssignPermissionsCommand}" IsEnabled="{Binding HasSelectedRole}"/>
              </StackPanel>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>
