<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             x:Class="Lumine.AuthPortal.Views.Pages.ConsentPageView"
             x:DataType="vm:ConsentPageViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16">
      <Border Classes="admin-panel">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="授权确认" Classes="admin-card-title"/>
              <TextBlock Text="以真实的 `/connect/authorize` 预览结果为基础，完成授权批准或拒绝。" Classes="admin-hint"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="admin-button"
                    Content="刷新预览"
                    Command="{Binding RefreshCommand}"
                    IsEnabled="{Binding CanSubmitDecision}"/>
          </Grid>

          <Border Grid.Row="1" Classes="admin-status-banner" IsVisible="{Binding HasDecisionMessage}">
            <TextBlock Text="{Binding DecisionMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
          </Border>

          <Grid Grid.Row="2" ColumnDefinitions="1.25*,0.75*" ColumnSpacing="16">
            <StackPanel Spacing="16">
              <Border Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel Spacing="10">
                  <TextBlock Text="当前授权请求" Classes="admin-card-title"/>
                  <Border Classes="admin-pill admin-pill-muted" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding CurrentRequestSummary}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                  </Border>
                  <TextBlock Text="{Binding RedirectUri, StringFormat=回调地址：{0}}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding RequestedScopes, StringFormat=申请 Scope：{0}}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <Border Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
                <StackPanel Spacing="10">
                  <TextBlock Text="操作" Classes="admin-card-title"/>
                  <TextBlock Text="批准后将签发授权码；拒绝后将返回标准错误响应。" Classes="admin-hint" TextWrapping="Wrap"/>
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="admin-button admin-primary"
                            Content="批准授权"
                            Command="{Binding ApproveCommand}"
                            IsEnabled="{Binding CanSubmitDecision}"/>
                    <Button Classes="admin-button admin-danger"
                            Content="拒绝授权"
                            Command="{Binding DenyCommand}"
                            IsEnabled="{Binding CanSubmitDecision}"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="16">
              <Border Classes="info-card">
                <StackPanel Spacing="8">
                  <TextBlock Text="PKCE / 状态参数" Classes="admin-card-title"/>
                  <TextBlock Text="{Binding PkceSummary}" Classes="admin-hint" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>

              <Border Classes="info-card">
                <StackPanel Spacing="8">
                  <TextBlock Text="说明" Classes="admin-card-title"/>
                  <TextBlock Text="页面会在加载时自动生成新的 state、nonce 和 code challenge，方便直接联调授权流程。" Classes="admin-hint" TextWrapping="Wrap"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>

          <TextBlock Grid.Row="3"
                     Text="{Binding State, StringFormat=当前 state：{0}}"
                     Classes="admin-hint"/>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
