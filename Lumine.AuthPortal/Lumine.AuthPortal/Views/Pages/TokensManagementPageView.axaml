<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             xmlns:model="using:Lumine.AuthPortal.Models"
             x:Class="Lumine.AuthPortal.Views.Pages.TokensManagementPageView"
             x:Name="Root"
             x:DataType="vm:TokensManagementPageViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16">
      <Border Classes="admin-panel" Padding="18">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="Token 管理" Classes="admin-card-title"/>
              <TextBlock Text="查看 refresh token 的签发、到期与撤销状态，并支持即时撤销。" Classes="admin-hint"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Classes="admin-icon-button"
                      Command="{Binding ToggleSearchCommand}"
                      Click="ToggleSearchButton_OnClick"
                      ToolTip.Tip="搜索 Token">
                <PathIcon Data="{Binding SearchIconData}" Classes="admin-button-icon"/>
              </Button>
              <Button Classes="admin-icon-button"
                      Command="{Binding LoadCommand}"
                      ToolTip.Tip="刷新列表">
                <PathIcon Data="{Binding RefreshIconData}" Classes="admin-button-icon"/>
              </Button>
            </StackPanel>
          </Grid>

          <Border Grid.Row="1"
                  Classes="admin-search-shell"
                  IsVisible="{Binding IsSearchVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
              <TextBox x:Name="SearchKeywordTextBox"
                       Classes="admin-search-input"
                       Text="{Binding SearchKeyword}"
                       Watermark="搜索 Token、用户或客户端，按 Enter 执行"
                       KeyDown="SearchKeywordTextBox_OnKeyDown"/>
              <Button Grid.Column="1"
                      Classes="admin-row-icon-button"
                      Command="{Binding ClearSearchCommand}"
                      ToolTip.Tip="清空搜索">
                <PathIcon Data="{Binding ClearSearchIconData}" Classes="admin-row-button-icon"/>
              </Button>
            </Grid>
          </Border>

          <Border Grid.Row="2" Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
            <Grid RowDefinitions="Auto,Auto,*">
              <Grid ColumnDefinitions="120,130,140,170,120,120,*" ColumnSpacing="12" Margin="2,0,2,10">
                <TextBlock Text="Token" Classes="admin-table-header"/>
                <TextBlock Grid.Column="1" Text="用户" Classes="admin-table-header"/>
                <TextBlock Grid.Column="2" Text="客户端" Classes="admin-table-header"/>
                <TextBlock Grid.Column="3" Text="Scope" Classes="admin-table-header"/>
                <TextBlock Grid.Column="4" Text="签发时间" Classes="admin-table-header"/>
                <TextBlock Grid.Column="5" Text="到期时间" Classes="admin-table-header"/>
                <TextBlock Grid.Column="6" Text="状态 / 操作" Classes="admin-table-header"/>
              </Grid>

              <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderSubtleBrush}"/>

              <Grid Grid.Row="2">
                <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" Background="Transparent" BorderThickness="0" Margin="0,10,0,0" IsVisible="{Binding HasTokens}">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="model:RefreshTokenRecordDto">
                      <Border Classes="admin-row-card" Margin="0,0,0,8" Padding="10">
                        <Grid ColumnDefinitions="120,130,140,170,120,120,*" ColumnSpacing="12">
                          <TextBlock Text="{Binding TokenPreview}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="1" Text="{Binding UserName}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="2" Text="{Binding ClientName}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="3" Text="{Binding ScopesDisplay}" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                          <TextBlock Grid.Column="4" Text="{Binding CreatedAtUtc, StringFormat={}{0:MM-dd HH:mm}}" Classes="admin-muted" VerticalAlignment="Center"/>
                          <TextBlock Grid.Column="5" Text="{Binding ExpiresAtUtc, StringFormat={}{0:MM-dd HH:mm}}" Classes="admin-muted" VerticalAlignment="Center"/>
                          <Grid Grid.Column="6" ColumnDefinitions="Auto,Auto" ColumnSpacing="8">
                            <Border Classes="admin-pill admin-pill-muted" VerticalAlignment="Center">
                              <TextBlock Text="{Binding RevokedStatusText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <Button Grid.Column="1" Classes="admin-row-icon-button admin-danger"
                                    Command="{Binding DataContext.RevokeTokenCommand, ElementName=Root}"
                                    CommandParameter="{Binding}"
                                    ToolTip.Tip="撤销 Token">
                              <PathIcon Data="{Binding DataContext.ConfirmDeleteIconData, ElementName=Root}" Classes="admin-row-button-icon"/>
                            </Button>
                          </Grid>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>

                <Border Classes="info-card" IsVisible="{Binding ShowEmptyState}" VerticalAlignment="Center">
                  <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="暂无 Token 记录" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="完成一次授权码换 Token 后，这里会显示真实的 refresh token 记录。" Classes="admin-hint" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>
            </Grid>
          </Border>

          <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="10">
              <Border Classes="admin-status-banner" Padding="10,8">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
              </Border>
              <Border Classes="admin-danger-banner" IsVisible="{Binding HasPendingRevoke}" HorizontalAlignment="Left">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <TextBlock Text="{Binding DeleteConfirmationText}" Foreground="{DynamicResource TextOnAccentBrush}" VerticalAlignment="Center"/>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Classes="admin-icon-button admin-danger-solid" Command="{Binding ConfirmDeleteCommand}" ToolTip.Tip="确认撤销">
                      <PathIcon Data="{Binding ConfirmDeleteIconData}" Classes="admin-button-icon"/>
                    </Button>
                    <Button Classes="admin-icon-button" Command="{Binding CancelDeleteCommand}" ToolTip.Tip="取消撤销">
                      <PathIcon Data="{Binding CancelIconData}" Classes="admin-button-icon"/>
                    </Button>
                  </StackPanel>
                </Grid>
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <ComboBox Width="92"
                        ItemsSource="{Binding PageSizeOptions}"
                        SelectedItem="{Binding SelectedPageSize}"
                        HorizontalContentAlignment="Center"/>
              <Button Classes="admin-icon-button"
                      Command="{Binding PreviousPageCommand}"
                      IsEnabled="{Binding CanGoPreviousPage}"
                      ToolTip.Tip="上一页">
                <PathIcon Data="{Binding PreviousPageIconData}" Classes="admin-button-icon"/>
              </Button>
              <Border Classes="admin-pill admin-pill-muted" VerticalAlignment="Center">
                <TextBlock Text="{Binding PaginationSummaryText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
              </Border>
              <Button Classes="admin-icon-button"
                      Command="{Binding NextPageCommand}"
                      IsEnabled="{Binding CanGoNextPage}"
                      ToolTip.Tip="下一页">
                <PathIcon Data="{Binding NextPageIconData}" Classes="admin-button-icon"/>
              </Button>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
