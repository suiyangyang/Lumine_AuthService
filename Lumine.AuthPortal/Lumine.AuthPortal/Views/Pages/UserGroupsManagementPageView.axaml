<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumine.AuthPortal.ViewModels.Pages"
             xmlns:model="using:Lumine.AuthPortal.Models"
             x:Class="Lumine.AuthPortal.Views.Pages.UserGroupsManagementPageView"
             x:Name="Root"
             x:DataType="vm:UserGroupsManagementPageViewModel">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <StackPanel Spacing="16">
      <Border Classes="admin-panel" Padding="18">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="用户组管理" Classes="admin-card-title"/>
              <TextBlock Text="基于现有角色聚合成员和权限，提供当前系统的用户组视图。" Classes="admin-hint"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Classes="admin-icon-button"
                      Command="{Binding ToggleSearchCommand}"
                      Click="ToggleSearchButton_OnClick"
                      ToolTip.Tip="搜索用户组">
                <PathIcon Data="{Binding SearchIconData}" Classes="admin-button-icon"/>
              </Button>
              <Button Classes="admin-icon-button"
                      Command="{Binding LoadCommand}"
                      ToolTip.Tip="刷新列表">
                <PathIcon Data="{Binding RefreshIconData}" Classes="admin-button-icon"/>
              </Button>
            </StackPanel>
          </Grid>

          <Border Grid.Row="1"
                  Classes="admin-search-shell"
                  IsVisible="{Binding IsSearchVisible}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
              <TextBox x:Name="SearchKeywordTextBox"
                       Classes="admin-search-input"
                       Text="{Binding SearchKeyword}"
                       Watermark="搜索用户组名称、类型或权限摘要，按 Enter 执行"
                       KeyDown="SearchKeywordTextBox_OnKeyDown"/>
              <Button Grid.Column="1"
                      Classes="admin-row-icon-button"
                      Command="{Binding ClearSearchCommand}"
                      ToolTip.Tip="清空搜索">
                <PathIcon Data="{Binding ClearSearchIconData}" Classes="admin-row-button-icon"/>
              </Button>
            </Grid>
          </Border>

          <Border Grid.Row="2" Background="{DynamicResource SurfaceInsetBrush}" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="12" Padding="12">
            <Grid ColumnDefinitions="1.2*,0.95*" ColumnSpacing="16">
              <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                  <TextBlock Text="用户组列表" Classes="admin-card-title"/>
                  <ComboBox Grid.Column="1"
                            Width="92"
                            ItemsSource="{Binding PageSizeOptions}"
                            SelectedItem="{Binding SelectedPageSize}"
                            HorizontalContentAlignment="Center"/>
                  <Button Grid.Column="2"
                          Classes="admin-icon-button"
                          Command="{Binding PreviousPageCommand}"
                          IsEnabled="{Binding CanGoPreviousPage}"
                          ToolTip.Tip="上一页">
                    <PathIcon Data="{Binding PreviousPageIconData}" Classes="admin-button-icon"/>
                  </Button>
                  <Button Grid.Column="3"
                          Classes="admin-icon-button"
                          Command="{Binding NextPageCommand}"
                          IsEnabled="{Binding CanGoNextPage}"
                          ToolTip.Tip="下一页">
                    <PathIcon Data="{Binding NextPageIconData}" Classes="admin-button-icon"/>
                  </Button>
                </Grid>

                <Grid Grid.Row="1">
                  <ListBox ItemsSource="{Binding Items}"
                           SelectedItem="{Binding SelectedItem}"
                           Background="Transparent"
                           BorderThickness="0"
                           IsVisible="{Binding HasGroups}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="model:UserGroupDto">
                        <Border Classes="admin-row-card" Margin="0,0,0,10" Padding="14">
                          <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                              <StackPanel Spacing="4">
                                <TextBlock Text="{Binding GroupName}"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="16"/>
                                <TextBlock Text="{Binding GroupType}" Classes="admin-hint"/>
                              </StackPanel>
                              <Border Grid.Column="1" Classes="admin-pill admin-pill-muted" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="{Binding MemberCount, StringFormat={}{0} 成员}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                              </Border>
                            </Grid>

                            <WrapPanel ItemHeight="28">
                              <Border Classes="admin-pill admin-pill-muted" Margin="0,0,8,8">
                                <TextBlock Text="{Binding PermissionCount, StringFormat={}{0} 项权限}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                              </Border>
                              <Border Classes="admin-pill admin-pill-muted" Margin="0,0,8,8">
                                <TextBlock Text="{Binding RoleSummary}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                              </Border>
                            </WrapPanel>

                            <TextBlock Text="{Binding PermissionSummary}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxLines="3"/>
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>

                  <Border Classes="info-card" IsVisible="{Binding ShowEmptyState}" VerticalAlignment="Center">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                      <TextBlock Text="暂无用户组数据" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                      <TextBlock Text="当前页面基于角色聚合展示，创建角色后会自动形成新的用户组视图。" Classes="admin-hint" HorizontalAlignment="Center"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </Grid>

              <Border Grid.Column="1" Classes="info-card">
                <StackPanel Spacing="12">
                  <StackPanel Spacing="4">
                    <TextBlock Text="用户组详情" Classes="admin-card-title"/>
                    <TextBlock Text="{Binding SelectedItem.GroupName, TargetNullValue=未选择用户组}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold"
                               FontSize="16"/>
                    <TextBlock Text="{Binding SelectedGroupMetaSummary}" Classes="admin-hint" TextWrapping="Wrap"/>
                  </StackPanel>

                  <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="12">
                    <StackPanel Spacing="6">
                      <TextBlock Text="角色映射" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding SelectedGroupRoleSummary}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>

                  <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="12">
                    <StackPanel Spacing="6">
                      <TextBlock Text="权限摘要" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding SelectedGroupPermissionSummary}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>

                  <Border Background="{DynamicResource SurfaceSoftBrush}" CornerRadius="10" Padding="12">
                    <StackPanel Spacing="6">
                      <TextBlock Text="成员明细" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding SelectedGroupMembersText}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
            </Grid>
          </Border>

          <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="10">
              <Border Classes="admin-status-banner" Padding="10,8">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource StatusInfoBrush}" TextWrapping="Wrap"/>
              </Border>
            </StackPanel>

            <Border Grid.Column="1" Classes="admin-pill admin-pill-muted" VerticalAlignment="Center">
              <TextBlock Text="{Binding PaginationSummaryText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>
          </Grid>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
