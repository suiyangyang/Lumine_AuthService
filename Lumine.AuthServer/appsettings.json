{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Oidc": {
    "Issuer": "http://localhost:5115",
    "KeyId": "lumine-auth-rsa-key",
    "PrivateKeyPem": null,
    "GenerateDevelopmentKey": true
  },
  "SeedData": {
    "Enabled": true,
    "AdminUserName": "admin",
    "AdminEmail": "admin@lumine.local",
    "AdminPassword": "",
    "AdminRoleName": "Admin",
    "ForceUpdateAdminPassword": false,
    "Permissions": [
      {
        "Name": "users.view",
        "DisplayName": "查看用户"
      },
      {
        "Name": "users.manage",
        "DisplayName": "管理用户"
      },
      {
        "Name": "roles.view",
        "DisplayName": "查看角色"
      },
      {
        "Name": "roles.manage",
        "DisplayName": "管理角色"
      },
      {
        "Name": "permissions.view",
        "DisplayName": "查看权限"
      },
      {
        "Name": "permissions.manage",
        "DisplayName": "管理权限"
      },
      {
        "Name": "clients.view",
        "DisplayName": "查看客户端"
      },
      {
        "Name": "clients.manage",
        "DisplayName": "管理客户端"
      }
    ],
    "Clients": [
      {
        "ClientId": "lumine-demo-client",
        "ClientName": "Lumine Demo Client",
        "ClientType": "public",
        "AllowedScopes": [
          "openid",
          "profile",
          "email",
          "roles",
          "permissions"
        ],
        "RedirectUris": [
          "http://localhost:5173/signin-oidc"
        ],
        "RequirePkce": true,
        "IsActive": true,
        "Description": "默认演示客户端"
      }
    ]
  }
}
